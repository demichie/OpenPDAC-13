FoamFile
{
    format ascii;
    class dictionary;
    object blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Include shared geometry parameters
#include "../constant/geometryParameters"

#codeStream {

codeInclude
#{
#include "scalarList.H"
#};

    code #
{

    scalar ringCoeff = 1.1;

    // NOTE: this version introduces a straight intermediate edge in the
    // original outer Block1/Block3.  Run blockMesh and checkMesh to verify
    // whether the unchanged corner Block2 remains acceptable for your case;
    // if blockMesh reports unmatched internal faces, Block2 must also be
    // split conformally.

    const Foam::scalarList& atmCells_aspect_ratio_bottom =
        dict.lookup("atmCells_aspect_ratio_bottom");
    const Foam::scalarList& atmCells_aspect_ratio_top =
        dict.lookup("atmCells_aspect_ratio_top");

    bool square_flag = dict.lookupOrDefault<bool>("square_flag", false);
    
    List<scalar> layer_fraction($n_vert_layers + 1, 0.0);

    layer_fraction[$n_vert_layers] = 1.0;            
    scalar delta_z($dz_ratio);

    scalar c_bottom = atmCells_aspect_ratio_bottom[0];
    scalar c_top = atmCells_aspect_ratio_top[0]; 
    scalar dz_bottom = $crater_cell_size * c_bottom;
    scalar dz_top = $hor_cell_size_topo * c_top;

    scalar zlayer_rel = 0.0;
    
    for (label layer = 0; layer <= $n_vert_layers-2; ++layer)
    {
        label N = round( Foam::log(dz_top/dz_bottom) / Foam::log(delta_z));
        Info << "N " << N << endl;
        Info << "dz_bottom " << dz_bottom << endl; 
        Info << "dz_top " << dz_top << endl; 
        scalar z_layer = dz_bottom * ( 1.0 - pow(delta_z,N+1) ) / ( 1.0 - delta_z);
        Info << "z_layer " << z_layer << endl;

        zlayer_rel += (z_layer/$atm_top_z);
        Info << "z_layer_rel " << zlayer_rel << endl;

        layer_fraction[layer+1] = zlayer_rel;

        c_top = atmCells_aspect_ratio_top[layer];
        c_bottom = atmCells_aspect_ratio_bottom[layer];
        dz_bottom = $hor_cell_size_topo * pow(2.0,layer+1) * c_bottom;
        dz_top = $hor_cell_size_topo * pow(2.0,layer+1) * c_top;
        
    }

    Info << "layer_fraction " << layer_fraction << endl;

    // --- Helper Function for Geometric Grading Calculation (using auto/lambda)
    // ---
    auto calculateGradingCells =
        [&]( // Usa [&] per catturare per riferimento, o [] se non serve accesso
             // a variabili esterne
            scalar totalLength,
            scalar cellSizeStart,
            scalar cellSizeEnd,
            label& nCells,
            scalar& grading,
            label maxIter = 50, // Puoi ancora usare valori di default
            scalar tolerance =
                1e-4) -> void // Specifica il tipo di ritorno (opzionale ma
                              // buona pratica per chiarezza)
    {
        // --- Inizio del corpo della funzione (lambda) ---
        nCells = 0;
        grading = 1.0;

        if (totalLength < 1e-9)
        {
            return;
        }
        if (cellSizeStart < 1e-9 || cellSizeEnd < 1e-9)
        {
            Info << "Warning in calculateGradingCells: cellSizeStart or "
                    "cellSizeEnd is near zero. "
                 << "Falling back to single cell." << endl;
            nCells = 1;
            grading = 1.0;
            return;
        }
        if (Foam::mag(cellSizeEnd - cellSizeStart) < 1e-9 * cellSizeStart)
        {
            nCells = Foam::max(1, label(round(totalLength / cellSizeStart)));
            grading = 1.0;
            return;
        }

        scalar r = cellSizeEnd / cellSizeStart;
        scalar K = totalLength / cellSizeStart;

        if (r <= 1.0 + 1e-6 || K <= 1.0 + 1e-6)
        {
            nCells = Foam::max(1, label(round(totalLength / cellSizeStart)));
            grading = 1.0;
            return;
        }

        scalar n0 = Foam::max(1.0 + tolerance, K / r);
        scalar n2 = K;

        if (n2 < n0 || ceil(n0) >= floor(n2))
        {
            nCells = Foam::max(1, label(round(totalLength / cellSizeStart)));
            grading = 1.0;
            return;
        }

        // Definisci la funzione f(n) interna alla lambda principale
        auto calculateF = [&](scalar n_val) -> scalar {
            if (n_val <= 1.0 + 1e-6)
                return -K;
            scalar rn = pow(r, n_val / (n_val - 1.0));
            scalar r1 = pow(r, 1.0 / (n_val - 1.0));
            if (Foam::mag(r1 - 1.0) < 1e-9)
                return -K;
            return (rn - 1.0) / (r1 - 1.0) - K;
        }; // Fine della lambda interna calculateF

        scalar f0 = calculateF(n0);
        scalar n1 = 0.5 * (n0 + n2);
        scalar f1 = calculateF(n1);

        label iter = 0;
        while (Foam::mag(n2 - n0) > tolerance && iter < maxIter)
        {
            iter++;
            if (f0 * f1 < 0)
            {
                n2 = n1;
            }
            else
            {
                n0 = n1;
                f0 = f1;
            }
            n1 = 0.5 * (n0 + n2);
            f1 = calculateF(n1);
        }

        nCells = Foam::max(1, label(round(n1)));
        grading = (nCells <= 1) ? 1.0 : r;
    };

// --------------------------------------------------------------------
        // Structure to return solver results
        // --------------------------------------------------------------------
        struct RingParams {
            scalar R_icyl;   // Calculated outer radius for the ring
            scalar grading;  // simpleGrading value (last_cell / first_cell)
        };

        // --------------------------------------------------------------------
        // Helper: cell size in the inner part of the split outer edge blocks.
        // The length is the effective axis-aligned segment from the Icyl axis
        // point to the corresponding Mid axis point after the Mid axis point
        // has been aligned with the corner-side Mid points.
        // --------------------------------------------------------------------
        auto axisAlignedBlockInCellSize = [&](scalar R_axis, scalar L_far_field, label N_outer, label N_inner) -> scalar
        {
            N_outer = Foam::max(1, N_outer);
            N_inner = Foam::max(1, N_inner);

            scalar f = scalar(N_inner)/scalar(N_outer);
            f = Foam::max(0.0, Foam::min(1.0, f));

            scalar r_diag = R_axis*sqrt(0.5);
            scalar L_in = f*L_far_field + (1.0 - f)*r_diag - R_axis;

            if (L_in <= 1e-12)
            {
                scalar L_fallback = Foam::max(1e-12, L_far_field - R_axis);
                return L_fallback/scalar(N_outer);
            }

            return L_in/scalar(N_inner);
        };

        // --------------------------------------------------------------------
        // SOLVER: Calculates R_icyl and radial grading.  The final cell size
        // is matched to the actual Icyl->Mid length of Block1In/Block3In,
        // not to the remaining distance from Icyl to the far boundary.
        // --------------------------------------------------------------------
        auto solveRingParameters = [&](scalar R_inner, scalar d_start, label N_ring, scalar L_far_field, label N_outer, label N_inner) -> RingParams 
        {
            // Limits for the geometric expansion ratio 'r'
            // r < 1: compression, r > 1: expansion
            scalar r_min = 0.5;
            scalar r_max = 2.0;
            
            // Bisection variables
            scalar r_low = r_min;
            scalar r_high = r_max;
            scalar r_sol = 1.0;
            
            // Tolerance based on the starting cell size
            scalar tolerance = 1e-5 * d_start;
            int max_iter = 100;

            for (int iter = 0; iter < max_iter; ++iter) {
                scalar r = 0.5 * (r_low + r_high);
                
                // 1. Calculate ring width (Geometric series sum)
                scalar ring_width;
                scalar d_end_ring;

                // Handle case r ~ 1.0 to avoid division by zero
                if (Foam::mag(r - 1.0) < 1e-6) {
                    ring_width = d_start * N_ring;
                    d_end_ring = d_start;
                } else {
                    ring_width = d_start * (pow(r, N_ring) - 1.0) / (r - 1.0);
                    d_end_ring = d_start * pow(r, N_ring - 1);
                }

                scalar R_curr = R_inner + ring_width;
                
                // 2. Calculate target cell size at Icyl from the actual
                // Icyl->Mid length of the inner split outer block.
                scalar space_remaining = L_far_field - R_curr;

                // Safety check: if the ring becomes too large and touches the boundary,
                // drastically reduce the upper limit of r
                if (space_remaining < 1e-3 * L_far_field) {
                    r_high = r;
                    continue;
                }

                scalar d_start_outer = axisAlignedBlockInCellSize(R_curr, L_far_field, N_outer, N_inner);

                // 3. Check Error (Discontinuity at the interface)
                scalar error = d_end_ring - d_start_outer;

                // Convergence reached?
                if (Foam::mag(error) < tolerance) {
                    r_sol = r;
                    break;
                }

                // 4. Update Bisection
                // If d_end > d_outer (Error > 0), the grading is too aggressive.
                // Since Error increases monotonically with r, we must reduce r.
                if (error > 0) {
                    r_high = r;
                } else {
                    r_low = r;
                }
                r_sol = r;
            }

            // Calculate final results using the found solution
            scalar final_width;
            if (Foam::mag(r_sol - 1.0) < 1e-6) {
                final_width = d_start * N_ring;
            } else {
                final_width = d_start * (pow(r_sol, N_ring) - 1.0) / (r_sol - 1.0);
            }

            // In OpenFOAM, simpleGrading is defined as (LastCell / FirstCell)
            // This is equivalent to r^(N-1)
            scalar final_grading = pow(r_sol, N_ring - 1);

            return RingParams{R_inner + final_width, final_grading};
        };


    int n_mult = pow(2, $n_vert_layers - 1);

    scalar hor_cell_size_top_atm($hor_cell_size_topo * n_mult);

    // --- Basic Calculations ---
    scalar radAngle = degToRad(45);
    scalar conduit_base_z = -1.0 * ($h_conduit + $h_crater);
    scalar crater_base_z = -1.0 * $h_crater;

    // Radii
    scalar r_cond_base = $r_conduit_base;
    scalar r_cr_base = $r_crater_base;
    scalar r_cr_top =
        $r_crater_top; // Also radius for Octagon and Inner Circle at z=0+
    scalar r_icyl =
        hor_cell_size_top_atm / cos(radAngle); // Intermediate Cylinder radius

    // Corner coordinates cache (based on 45 deg for NE/SE/SW/NW)
    auto getCorners = [&](scalar radius) {
        struct Coords
        {
            scalar x, y;
        };
        return Coords {radius * cos(radAngle), radius * sin(radAngle)};
    };
    auto corners_icyl = getCorners(r_icyl);

    int nx_pos_out =
        round((mag($atm_x_pos) - corners_icyl.x) / hor_cell_size_top_atm);
    nx_pos_out = Foam::max(1, nx_pos_out);
    int nx_neg_out =
        round((mag($atm_x_neg) - corners_icyl.x) / hor_cell_size_top_atm);
    nx_neg_out = Foam::max(1, nx_neg_out);
    int ny_pos_out =
        round((mag($atm_y_pos) - corners_icyl.y) / hor_cell_size_top_atm);
    ny_pos_out = Foam::max(1, ny_pos_out);
    int ny_neg_out =
        round((mag($atm_y_neg) - corners_icyl.y) / hor_cell_size_top_atm);
    ny_neg_out = Foam::max(1, ny_neg_out);
    int nx_pos_out_mult = nx_pos_out * n_mult;
    int nx_neg_out_mult = nx_neg_out * n_mult;
    int ny_pos_out_mult = ny_pos_out * n_mult;
    int ny_neg_out_mult = ny_neg_out * n_mult;

    // --- Outer edge split control ---
    // Block1 and Block3 of each outer quadrant are split radially into
    // In/Out parts.  The requested distance is absolute, but the realized
    // split is snapped to the closest cell index compatible with all
    // atmospheric layers, i.e. a multiple of 2^(n_vert_layers-1).
    scalar outerStraightEdgeDistance = dict.lookupOrDefault<scalar>
    (
        "outerStraightEdgeDistance",
        hor_cell_size_top_atm
    );

    label nOuterMinFine = Foam::min
    (
        Foam::min(nx_pos_out_mult, nx_neg_out_mult),
        Foam::min(ny_pos_out_mult, ny_neg_out_mult)
    );

    label nOuterEdgeInnerRaw = label(round(outerStraightEdgeDistance/$hor_cell_size_topo));
    label nOuterEdgeInnerFine = n_mult * label(round(scalar(nOuterEdgeInnerRaw)/scalar(n_mult)));

    nOuterEdgeInnerFine = Foam::max(n_mult, nOuterEdgeInnerFine);
    nOuterEdgeInnerFine = Foam::min(nOuterEdgeInnerFine, nOuterMinFine - n_mult);
    nOuterEdgeInnerFine = Foam::max(n_mult, nOuterEdgeInnerFine);

    Info << "outerStraightEdgeDistance target " << outerStraightEdgeDistance << endl;
    Info << "nOuterEdgeInnerFine snapped " << nOuterEdgeInnerFine
         << " using n_mult " << n_mult << endl;

    Info << "--- Automatically calculating n_crater (based on "
            "crater_cell_size) ---"
         << endl;

    scalar arg = (0.5 * $r_crater_top) / ($crater_cell_size);
    scalar R_calc = Foam::log(arg) / Foam::log(2.0);

    scalar n_crater = label(round((0.5 * $r_crater_top) / ($crater_cell_size)));

    scalar actual_crater_top_size = 0.5 * $r_crater_top / n_crater;

    Info << "  - Target horizontal crater cell size at z=0: "
         << $crater_cell_size << endl;
    Info << "  - Actual horizontal crater cell size at z=0: "
         << actual_crater_top_size << endl;

    Info << "  - Calculated R (float): " << R_calc << endl;

    Info << "--- Automatically calculating the interface ring  parameters ---"
         << endl;

    scalar l0_cyl = $hor_cell_size_topo * n_crater;

    Info << "   l0_cyl " << l0_cyl << endl;

    scalar l_cyl = l0_cyl / sin(degToRad(67.5));

    Info << "   l_cyl " << l_cyl << endl;

    scalar cyl_rad_base = l_cyl / (2.0 * cos(degToRad(67.5)));

    Info << "   cyl_rad_base " << cyl_rad_base << endl;

    scalar ring_width_const = cyl_rad_base - $r_crater_top;
    Info << "Constant width of the interface ring: " << ring_width_const
         << endl;

    label n_rad_gr_interface;
    scalar rad_gr_val;

    scalar drRatio = $hor_cell_size_topo / actual_crater_top_size;

    label n0 = 1;
    scalar alfa0 = pow(drRatio, 1.0 / (n0 + 1.0));
    scalar drTot0 = sqrt(actual_crater_top_size * $hor_cell_size_topo);

    // label n2 = ceil(ring_width_const / $hor_cell_size_topo);
    label n2 = ceil(ring_width_const / actual_crater_top_size);
    scalar alfa2 = pow(drRatio, 1.0 / (n2 + 1.0));
    scalar drTot2 =
        actual_crater_top_size * (alfa2 - pow(alfa2, n2+1)) / (1.0 - alfa2);

    Info << "n0 " << n0 << " n2 " << n2 << endl;
    Info << "alfa0 " << alfa0 << " alfa2 " << alfa2 << endl;
    Info << "drTot0 " << drTot0 << " drTot2 " << drTot2 << endl;

    scalar f0 = ring_width_const - drTot0;
    scalar f2 = ring_width_const - drTot2;
    
    Info << "f0 " << f0 << " f2 " << f2 << endl;

    label n1 = label(round(0.5 * (n0 + n2)));
    scalar alfa1 = pow(drRatio, 1.0 / (n1 + 1.0));
    scalar drTot1 =
        actual_crater_top_size * (alfa1 - pow(alfa1, n1+1)) / (1.0 - alfa1);
    scalar f1 = ring_width_const - drTot1;
    
    Info << "n1 " << n1 << " f1 " << f1 << endl;

    label iter = 0;

    while (iter < 10)
    {
        iter++;
        Info << "n0 " << n0 << " n1 " << n1 << " n2 " << n2 << endl;
        Info << "alfa0 " << alfa0 << " alfa1 " << alfa1 << " alfa2 " << alfa2 << endl;
        Info << "f0 " << f0 << " f1 " << f1 << " f2 " << f2 << endl;
        if ((n0 == n1) || (n1 == n2) || ( (n2-n0) == 1 ) )
        {
            if ((Foam::mag(f0)*alfa0) < (Foam::mag(f2)*alfa2))
            {
                Info << "Exit taking n0 " << n0 << " and drTot0 " << drTot0 << endl;
                drTot1 = drTot0;
                n1 = n0;
                alfa1 = alfa0;
                break;
            }
            else
            {
                Info << "Exit taking n2 " << n2 << " and drTot2 " << drTot2 << endl;
                drTot1 = drTot2;
                n1 = n2;
                alfa1 = alfa2;
                break;
            }
        }
        
        if (f0 * f1 < 0)
        {
            n2 = n1;
            f2 = f1;
            drTot2 = drTot1;
            alfa2 = alfa1;
        }
        else
        {
            n0 = n1;
            f0 = f1;
            drTot0 = drTot1;
            alfa0 = alfa1;
        }
        n1 = label(round(0.5 * (n0 + n2)));
        alfa1 = pow(drRatio, 1.0 / (n1 + 1.0));
        drTot1 = actual_crater_top_size * (alfa1 - pow(alfa1, n1+1))
            / (1.0 - alfa1);
        f1 = ring_width_const - drTot1;
        Info << "n1 " << n1 << " drTot1 " << drTot1 << " alfa1 " << alfa1 << " f1 " << f1 << endl  << endl;
    }

    Info << "Number of radial cell in ring " << n1 << endl;

    ring_width_const = drTot1;

    Info << "Corrected width of the interface ring: " << ring_width_const
         << endl;                  
                  
    rad_gr_val = pow(alfa1,n1-1);
    Info << "Radial ratio between consecutive cells in ring " << alfa1 << endl; 
    Info << "Ring grading " << rad_gr_val << endl; 
    n_rad_gr_interface = n1;

    /*
    calculateGradingCells(
        ring_width_const, actual_crater_top_size, $hor_cell_size_topo,
    n_rad_gr_interface, rad_gr_val); Info << "Calculated n_rad_gr_interface = "
    << n_rad_gr_interface
         << ", rad_gr_val = " << rad_gr_val << endl;
    */

    // ... (nz calculations remain the same) ...

    // Compute the grading and vertical number of cells in crater

    scalar dz_top_crater =
        atmCells_aspect_ratio_bottom[0] * r_cr_top / (2.0 * n_crater);
    scalar dz_bottom_crater =
        atmCells_aspect_ratio_bottom[0] * r_cr_base / (2.0 * n_crater);
    int nz_crater = 1;
    scalar z_crater_grading = 1.0;

    calculateGradingCells($h_crater,
                          dz_bottom_crater,
                          dz_top_crater,
                          nz_crater,
                          z_crater_grading);
    Info << "Calculated nz_crater = " << nz_crater
         << ", z_crater_grading = " << z_crater_grading << endl;


    int nz_conduit = 0;
    if ($h_conduit > 0)
    {
        nz_conduit =
            round( $h_conduit / dz_bottom_crater );
        nz_conduit = Foam::max(1, nz_conduit);
    }

    // Compute the grading and vertical number of cells in first layer
    scalar dz_atm_min = dz_top_crater;
    os << "dz_atm_min " << dz_atm_min << ";" << endl;
    Info << "dz_atm_min " << dz_atm_min << ";" << endl;

    scalar dz_atm_max = hor_cell_size_top_atm * atmCells_aspect_ratio_top[0]
        / pow(2, $n_vert_layers - 1);
    os << "dz_atm_max " << dz_atm_max << ";" << endl;
    Info << "dz_atm_max " << dz_atm_max << ";" << endl;

    scalar dz_bottom_layer($atm_top_z * layer_fraction[1]);
    Info << "dz_bottom_layer " << dz_bottom_layer << endl;

    label nz_out;
    scalar z_out_grading;
    calculateGradingCells(
        dz_bottom_layer, dz_atm_min, dz_atm_max, nz_out, z_out_grading);
    Info << "Calculated nz_out = " << nz_out
         << ", z_out_grading = " << z_out_grading << endl;

    os << "nz_out " << nz_out << ";" << endl;
    os << "z_out_grading " << z_out_grading << ";" << endl;

    // --- REVISED Vertex Generation (N=0, CCW) ---
    Info << "Revised Vertex Generation (N=0, CCW)" << endl;
    os << "vertices" << endl;
    os << "(" << endl;
    label vertexCount = 0;
    List<vector> points; // Store points

    // Helper function
    auto addVertex = [&](const vector& pt, const string& comment) {
        os << "(" << pt.x() << " " << pt.y() << " " << pt.z() << ") // "
           << vertexCount << " " << comment << endl;
        // Info << "(" << pt.x() << " " << pt.y() << " " << pt.z() << ") // " <<
        // vertexCount << " " << comment << endl;
        points.append(pt);
        vertexCount++;
        return vertexCount - 1; // Return the index
    };

    // Function to generate 8 points on a circle/octagon (N=0, CCW)
    auto makeRing = [&](label& startIdx,
                        scalar r,
                        scalar rCorner,
                        scalar z,
                        scalar dx,
                        scalar dy,
                        const string& prefix,
                        const string& type) {
        startIdx = vertexCount;
        addVertex(vector(dx + 0, dy + r, z),
                  prefix + " " + type + " N"); // Idx 0
        addVertex(vector(dx - rCorner, dy + rCorner, z),
                  prefix + " " + type + " NW"); // Idx 1
        addVertex(vector(dx - r, dy + 0, z),
                  prefix + " " + type + " W"); // Idx 2
        addVertex(vector(dx - rCorner, dy - rCorner, z),
                  prefix + " " + type + " SW"); // Idx 3
        addVertex(vector(dx + 0, dy - r, z),
                  prefix + " " + type + " S"); // Idx 4
        addVertex(vector(dx + rCorner, dy - rCorner, z),
                  prefix + " " + type + " SE"); // Idx 5
        addVertex(vector(dx + r, dy + 0, z),
                  prefix + " " + type + " E"); // Idx 6
        addVertex(vector(dx + rCorner, dy + rCorner, z),
                  prefix + " " + type + " NE"); // Idx 7
    };

    // --- Storage for Start Indices ---
    // Base Levels
    label L_condBase_center = -1;
    label L_condBase_oct_Start = -1, L_condBase_outer_Start = -1;

    label L_crBase_center = -1, L_crBase_oct_Start = -1,
          L_crBase_outer_Start = -1;

    // Atmospheric Layers (Index 0=unused, 1=z=0 base, 2=topL1/baseL2, ...)
    List<label> L_center_Start($n_vert_layers + 2, -1);
    List<label> L_oct_Start($n_vert_layers + 2, -1); // Octagon (r=rc_top)
    List<label> L_inr_Start($n_vert_layers + 2, -1); // Inner Circle (r=rc_top)
    List<label> L_inrDup_Start(
        $n_vert_layers + 2,
        -1); // Inner Circle Duplicates (only for L1 top / L2 base)
    List<label> L_icyl_Start($n_vert_layers + 2,
                             -1); // Intermediate Cylinder (r=cyl_radius)

    List<label> L_far_Start($n_vert_layers + 2, -1); // Far field
    List<label> L_mid_Start($n_vert_layers + 2, -1); // Intermediate straight edges inside outer blocks
    List<label> L_cornerSplit_Start($n_vert_layers + 2, -1); // Additional points to split outer corner blocks conformally

    // Indices of bottom vertices for layers > 1 (vertical duplicates)
    List<label> L_bottom_center_Start($n_vert_layers + 2, -1);
    List<label> L_bottom_oct_Start($n_vert_layers + 2, -1);
    List<label> L_bottom_inr_Start($n_vert_layers + 2, -1);
    List<label> L_bottom_inrDup_Start($n_vert_layers + 2, -1);
    List<label> L_bottom_icyl_Start($n_vert_layers + 2, -1);
    List<label> L_bottom_far_Start($n_vert_layers + 2, -1);
    List<label> L_bottom_mid_Start($n_vert_layers + 2, -1);
    List<label> L_bottom_cornerSplit_Start($n_vert_layers + 2, -1);

    // --- Conduit Base Vertices (z = conduit_base_z) ---
    if ($h_conduit > 0)
    {
        scalar z = conduit_base_z;
        scalar dx = $dx_crater_base + $dx_conduit_base;
        scalar dy = $dy_crater_base + $dy_conduit_base;
        L_condBase_center = addVertex(vector(dx, dy, z), "CrBase Ctr");
        makeRing(L_condBase_oct_Start,
                 0.5 * r_cond_base,
                 ringCoeff * cos(radAngle) * 0.5 * r_cond_base,
                 z,
                 dx,
                 dy,
                 "CondBase",
                 "Oct");
        makeRing(L_condBase_outer_Start,
                 r_cond_base,
                 r_cond_base * cos(radAngle),
                 z,
                 dx,
                 dy,
                 "CondBase",
                 "Outer"); // Circle points
    }

    // --- Crater Base Vertices (z = crater_base_z) ---
    {
        scalar z = crater_base_z;
        scalar dx = $dx_crater_base;
        scalar dy = $dy_crater_base;
        L_crBase_center = addVertex(vector(dx, dy, z), "CrBase Ctr");
        Info << "vertexCount " << vertexCount << endl;
        makeRing(L_crBase_oct_Start,
                 0.5 * r_cr_base,
                 ringCoeff * cos(radAngle) * 0.5 * r_cr_base,
                 z,
                 dx,
                 dy,
                 "CrBase",
                 "Oct");
        Info << "vertexCount " << vertexCount << endl;
        makeRing(L_crBase_outer_Start,
                 r_cr_base,
                 r_cr_base * cos(radAngle),
                 z,
                 dx,
                 dy,
                 "CrBase",
                 "Outer"); // Circle points
        Info << "vertexCount " << vertexCount << endl;
        Info << "crater base indexes " << L_crBase_center << L_crBase_oct_Start
             << L_crBase_outer_Start << endl;
    }

    // List to store the calculated optimal grading for each layer.
    // Size is +1 because loop runs from 1 to n_vert_layers.
    List<scalar> storedGradings($n_vert_layers + 1, rad_gr_val);
    List<scalar> storedRadiusCyl($n_vert_layers + 1, $r_crater_top + ring_width_const);

    // Recompute the bottom radial grading target using the actual Icyl->Mid
    // length of the inner split outer blocks at z=0.  The radius is left as
    // obtained from the existing bottom-ring calculation; only the target
    // grading ratio is updated to match Block1In/Block3In.
    {
        scalar R0 = storedRadiusCyl[0];
        scalar dN = axisAlignedBlockInCellSize(R0, mag($atm_y_pos), ny_pos_out_mult, nOuterEdgeInnerFine);
        scalar dW = axisAlignedBlockInCellSize(R0, mag($atm_x_neg), nx_neg_out_mult, nOuterEdgeInnerFine);
        scalar dS = axisAlignedBlockInCellSize(R0, mag($atm_y_neg), ny_neg_out_mult, nOuterEdgeInnerFine);
        scalar dE = axisAlignedBlockInCellSize(R0, mag($atm_x_pos), nx_pos_out_mult, nOuterEdgeInnerFine);
        scalar dTarget0 = 0.25*(dN + dW + dS + dE);

        scalar dMin0 = Foam::min(Foam::min(dN, dW), Foam::min(dS, dE));
        scalar dMax0 = Foam::max(Foam::max(dN, dW), Foam::max(dS, dE));
        if (Foam::mag(dMax0 - dMin0) > 1e-6*Foam::max(1.0, dTarget0))
        {
            Info << "Warning: bottom BlockIn target cell sizes are not identical: "
                 << dN << " " << dW << " " << dS << " " << dE << endl;
        }

        storedGradings[0] = dTarget0/actual_crater_top_size;
        Info << "Bottom radial grading retargeted to BlockIn cell size "
             << dTarget0 << ", grading " << storedGradings[0] << endl;
    }

    // --- External far-field split positions for horizontal layer interfaces ---
    // These control the intermediate points on the outer rectangular boundary
    // used by the 12 far-field blocks.  The values are defined per horizontal
    // level so that the top of layer L and the bottom of layer L+1 use exactly
    // the same coordinates.
    //
    // Add one of these optional entries to constant/geometryParameters:
    //
    //     outerSplitStrategy 3;
    //     outerSplitWeight   0.5;
    //
    // outerSplitStrategy:
    //   1 = use the split that gives uniform external-edge cells at the top
    //       of the lower layer;
    //   2 = use the split that gives uniform external-edge cells at the bottom
    //       of the upper layer;
    //   3 = use a weighted average of the two splits.
    //
    // outerSplitWeight is used only by strategy 3:
    //   split = outerSplitWeight*splitTopLower
    //         + (1 - outerSplitWeight)*splitBottomUpper.
    label outerSplitStrategy = dict.lookupOrDefault<label>("outerSplitStrategy", 3);
    scalar outerSplitWeight = dict.lookupOrDefault<scalar>("outerSplitWeight", 0.5);

    if (outerSplitStrategy < 1 || outerSplitStrategy > 3)
    {
        Info << "Warning: invalid outerSplitStrategy=" << outerSplitStrategy
             << ". Falling back to 3 (weighted average)." << endl;
        outerSplitStrategy = 3;
    }

    outerSplitWeight = Foam::max(0.0, Foam::min(1.0, outerSplitWeight));

    List<scalar> farSplit_xp($n_vert_layers + 1, 0.0);
    List<scalar> farSplit_xn($n_vert_layers + 1, 0.0);
    List<scalar> farSplit_yp($n_vert_layers + 1, 0.0);
    List<scalar> farSplit_yn($n_vert_layers + 1, 0.0);

    auto splitForUniformExternalEdge = [&](scalar boundaryMag, scalar nOuter) -> scalar
    {
        nOuter = Foam::max(1.0, nOuter);
        return boundaryMag * scalar(n_crater) / (scalar(n_crater) + nOuter);
    };

    auto selectInterfaceSplit = [&](scalar splitTopLower, scalar splitBottomUpper) -> scalar
    {
        if (outerSplitStrategy == 1)
        {
            return splitTopLower;
        }
        else if (outerSplitStrategy == 2)
        {
            return splitBottomUpper;
        }

        return outerSplitWeight*splitTopLower
             + (1.0 - outerSplitWeight)*splitBottomUpper;
    };

    // Level 0 is the bottom of the first atmospheric layer.  Keep the current
    // behaviour: split chosen for uniform external-edge cells at that level.
    farSplit_xp[0] = splitForUniformExternalEdge(mag($atm_x_pos), nx_pos_out_mult);
    farSplit_xn[0] = splitForUniformExternalEdge(mag($atm_x_neg), nx_neg_out_mult);
    farSplit_yp[0] = splitForUniformExternalEdge(mag($atm_y_pos), ny_pos_out_mult);
    farSplit_yn[0] = splitForUniformExternalEdge(mag($atm_y_neg), ny_neg_out_mult);

    // Intermediate levels are layer interfaces.  Compute the split once per
    // level and use it both for top(layer) and bottom(layer+1).
    for (label level = 1; level < $n_vert_layers; ++level)
    {
        scalar divLower = pow(2.0, level - 1); // layer below = level
        scalar divUpper = pow(2.0, level);     // layer above = level+1

        scalar nxpLower = scalar(nx_pos_out_mult)/divLower;
        scalar nxnLower = scalar(nx_neg_out_mult)/divLower;
        scalar nypLower = scalar(ny_pos_out_mult)/divLower;
        scalar nynLower = scalar(ny_neg_out_mult)/divLower;

        scalar nxpUpper = scalar(nx_pos_out_mult)/divUpper;
        scalar nxnUpper = scalar(nx_neg_out_mult)/divUpper;
        scalar nypUpper = scalar(ny_pos_out_mult)/divUpper;
        scalar nynUpper = scalar(ny_neg_out_mult)/divUpper;

        farSplit_xp[level] = selectInterfaceSplit(
            splitForUniformExternalEdge(mag($atm_x_pos), nxpLower),
            splitForUniformExternalEdge(mag($atm_x_pos), nxpUpper));
        farSplit_xn[level] = selectInterfaceSplit(
            splitForUniformExternalEdge(mag($atm_x_neg), nxnLower),
            splitForUniformExternalEdge(mag($atm_x_neg), nxnUpper));
        farSplit_yp[level] = selectInterfaceSplit(
            splitForUniformExternalEdge(mag($atm_y_pos), nypLower),
            splitForUniformExternalEdge(mag($atm_y_pos), nypUpper));
        farSplit_yn[level] = selectInterfaceSplit(
            splitForUniformExternalEdge(mag($atm_y_neg), nynLower),
            splitForUniformExternalEdge(mag($atm_y_neg), nynUpper));
    }

    // Level N is the top of the last atmospheric layer.  Keep the current
    // behaviour: split chosen for uniform external-edge cells at the domain top.
    {
        scalar divTop = pow(2.0, $n_vert_layers - 1);
        farSplit_xp[$n_vert_layers] = splitForUniformExternalEdge(
            mag($atm_x_pos), scalar(nx_pos_out_mult)/divTop);
        farSplit_xn[$n_vert_layers] = splitForUniformExternalEdge(
            mag($atm_x_neg), scalar(nx_neg_out_mult)/divTop);
        farSplit_yp[$n_vert_layers] = splitForUniformExternalEdge(
            mag($atm_y_pos), scalar(ny_pos_out_mult)/divTop);
        farSplit_yn[$n_vert_layers] = splitForUniformExternalEdge(
            mag($atm_y_neg), scalar(ny_neg_out_mult)/divTop);
    }

    Info << "outerSplitStrategy " << outerSplitStrategy
         << ", outerSplitWeight " << outerSplitWeight << endl;
    Info << "farSplit_xp " << farSplit_xp << endl;
    Info << "farSplit_xn " << farSplit_xn << endl;
    Info << "farSplit_yp " << farSplit_yp << endl;
    Info << "farSplit_yn " << farSplit_yn << endl;

    // Add the 16 intermediate straight-edge vertices used to split the
    // original outer Block1 and Block3 into In/Out parts.  Vertices are
    // placed along the segment from the corresponding Icyl point to the
    // corresponding Far point.  No arc is assigned to the Mid edges, so these
    // edges are straight in blockMesh.
    auto addMidOuterVertices = [&](label& startIdx, label icylStart, label farStart, const string& prefix)
    {
        startIdx = vertexCount;

        auto icylIndexForFar = [&](label farOffset) -> label
        {
            if (farOffset == 0) return 0;
            if (farOffset == 1 || farOffset == 2 || farOffset == 3) return 1;
            if (farOffset == 4) return 2;
            if (farOffset == 5 || farOffset == 6 || farOffset == 7) return 3;
            if (farOffset == 8) return 4;
            if (farOffset == 9 || farOffset == 10 || farOffset == 11) return 5;
            if (farOffset == 12) return 6;
            return 7;
        };

        auto nFineForFar = [&](label farOffset) -> label
        {
            if (farOffset == 0 || farOffset == 1 || farOffset == 15) return ny_pos_out_mult;
            if (farOffset == 3 || farOffset == 4 || farOffset == 5) return nx_neg_out_mult;
            if (farOffset == 7 || farOffset == 8 || farOffset == 9) return ny_neg_out_mult;
            if (farOffset == 11 || farOffset == 12 || farOffset == 13) return nx_pos_out_mult;

            // Corner helper vertices are not used by the 20-block split, but
            // keep a well-defined position for diagnostics/possible extensions.
            if (farOffset == 2) return Foam::min(nx_neg_out_mult, ny_pos_out_mult);
            if (farOffset == 6) return Foam::min(nx_neg_out_mult, ny_neg_out_mult);
            if (farOffset == 10) return Foam::min(nx_pos_out_mult, ny_neg_out_mult);
            return Foam::min(nx_pos_out_mult, ny_pos_out_mult);
        };

        List<vector> midPts(16);

        for (label k = 0; k < 16; ++k)
        {
            vector p0 = points[icylStart + icylIndexForFar(k)];
            vector p1 = points[farStart + k];
            scalar f = scalar(nOuterEdgeInnerFine)/scalar(nFineForFar(k));
            f = Foam::max(0.0, Foam::min(1.0, f));
            midPts[k] = p0 + f*(p1 - p0);
        }

        // Align only the four axis mid-points with the already computed
        // corner-side mid-points.  The corner-side mid-points stay unchanged;
        // only Mid 0, 4, 8 and 12 are shifted so that the In/Out interface
        // is parallel to the Cartesian grid lines used by the corner split.
        midPts[0].y()  = 0.5*(midPts[1].y()  + midPts[15].y()); // North axis
        midPts[4].x()  = 0.5*(midPts[3].x()  + midPts[5].x());  // West axis
        midPts[8].y()  = 0.5*(midPts[7].y()  + midPts[9].y());  // South axis
        midPts[12].x() = 0.5*(midPts[11].x() + midPts[13].x()); // East axis

        for (label k = 0; k < 16; ++k)
        {
            addVertex(midPts[k], prefix + " Mid " + Foam::name(k));
        }
    };


    auto addCornerOuterVertices = [&](label& cornerStart,
                                      label icylStart,
                                      label midStart,
                                      label farStart,
                                      const string& prefix)
    {
        cornerStart = vertexCount;

        auto nFineForFar = [&](label farOffset) -> label
        {
            if (farOffset == 0 || farOffset == 1 || farOffset == 15) return ny_pos_out_mult;
            if (farOffset == 3 || farOffset == 4 || farOffset == 5) return nx_neg_out_mult;
            if (farOffset == 7 || farOffset == 8 || farOffset == 9) return ny_neg_out_mult;
            if (farOffset == 11 || farOffset == 12 || farOffset == 13) return nx_pos_out_mult;
            if (farOffset == 2) return Foam::min(nx_neg_out_mult, ny_pos_out_mult);
            if (farOffset == 6) return Foam::min(nx_neg_out_mult, ny_neg_out_mult);
            if (farOffset == 10) return Foam::min(nx_pos_out_mult, ny_neg_out_mult);
            return Foam::min(nx_pos_out_mult, ny_pos_out_mult);
        };

        for (label i = 0; i < 4; ++i)
        {
            label icyl_idx_corn = (2*i + 1) % 8;
            label far_idx_prev1 = (4*i + 1) % 16;
            label far_idx_corn  = (4*i + 2) % 16;
            label far_idx_next1 = (4*i + 3) % 16;

            vector A  = points[icylStart + icyl_idx_corn];
            vector B  = points[farStart + far_idx_prev1];
            vector C  = points[farStart + far_idx_corn];
            vector D  = points[farStart + far_idx_next1];
            vector AB = points[midStart + far_idx_prev1];
            vector AD = points[midStart + far_idx_next1];

            scalar fx = scalar(nOuterEdgeInnerFine)/scalar(nFineForFar(far_idx_prev1));
            scalar fy = scalar(nOuterEdgeInnerFine)/scalar(nFineForFar(far_idx_next1));
            fx = Foam::max(0.0, Foam::min(1.0, fx));
            fy = Foam::max(0.0, Foam::min(1.0, fy));

            // Points on the two outer sides of the corner block, plus the
            // interior intersection.  These make the corner conformal with
            // the In/Out split on both adjacent edge blocks.
            vector BC = B + fy*(C - B);
            vector DC = D + fx*(C - D);
            vector P  = AB + fy*(DC - AB);

            addVertex(BC, prefix + " CornerSplit BC " + Foam::name(i));
            addVertex(DC, prefix + " CornerSplit DC " + Foam::name(i));
            addVertex(P,  prefix + " CornerSplit P "  + Foam::name(i));
        }
    };

    // --- Loop through atmospheric horizontal layers ---
    for (label layer = 1; layer <= $n_vert_layers; ++layer)
    {
        // Layer Index 'layer' runs 1 to N.
        // Vertex List Index 'layer+1' corresponds to the Bottom of layer
        // 'layer'. Vertex List Index 'layer' corresponds to the BOTTOM of layer
        // 'layer' (except for L1 base at z=0, handled above).

        scalar z_level;

        if (layer == 1)
        {
            z_level = $crater_top_z; // Base of Layer 1 is z=0
            r_icyl = $r_crater_top + ring_width_const;
        }
        else
        {
            // Bottom Z is the Top Z of the previous layer
            z_level = $atm_top_z * layer_fraction[layer - 1];
        }

        Info << "bottom level " << z_level << endl;

        r_cr_top = $r_crater_top * pow($exp_fact, layer - 1);

        scalar dx = 0.0; // Assuming centered
        scalar dy = 0.0;
        label listIdxBottom =
            layer; // Index in lists for vertices at the Bottom of this layer

        Info << "Generating vertices for Bottom of Layer " << layer
             << " (z=" << z_level << ", List Index " << listIdxBottom << ")"
             << endl;

        // --- Generate/reuse Bottom vertices for Layer 'layer' ---
        // For layer 1, the bottom is the terrain level z=0 and must be
        // generated explicitly.  For layer > 1, the central/inner/interface
        // part is conformal with the top of the previous layer, so reuse those
        // vertex indices instead of duplicating them.  Only Far vertices are
        // duplicated below, because the outer blocks can have different
        // horizontal cell counts and are merged with mergePatchPairs.
        if (layer == 1)
        {
            L_bottom_center_Start[listIdxBottom] = addVertex(
                vector(dx, dy, z_level), "L" + Foam::name(layer) + " Btm Ctr");
            makeRing(L_bottom_oct_Start[listIdxBottom],
                     0.5 * r_cr_top,
                     ringCoeff * cos(radAngle) * 0.5 * r_cr_top,
                     z_level,
                     dx,
                     dy,
                     "L" + Foam::name(layer) + " Btm",
                     "Oct");

            makeRing(L_bottom_inr_Start[listIdxBottom],
                     r_cr_top,
                     r_cr_top * cos(radAngle),
                     z_level,
                     dx,
                     dy,
                     "L" + Foam::name(layer) + " Btm",
                     "Inr");

            // No duplicate inner ring is required: inner blocks and radial
            // interface blocks are conformal within each layer.
            L_bottom_inrDup_Start[listIdxBottom] =
                L_bottom_inr_Start[listIdxBottom];

            scalar curvCoeff = cos(radAngle);

            scalar r_axis = r_icyl;
            scalar r_diag = r_icyl * curvCoeff;

            if (layer == 1 && square_flag)
            {
                r_axis = r_icyl * curvCoeff;
            }

            makeRing(L_bottom_icyl_Start[listIdxBottom],
                     r_axis,
                     r_diag,
                     z_level,
                     dx,
                     dy,
                     "L" + Foam::name(layer) + " Btm",
                     "ICyl");
        }
        else
        {
            label prev = layer - 1;
            L_bottom_center_Start[listIdxBottom] = L_center_Start[prev];
            L_bottom_oct_Start[listIdxBottom]    = L_oct_Start[prev];
            L_bottom_inr_Start[listIdxBottom]    = L_inr_Start[prev];
            L_bottom_inrDup_Start[listIdxBottom] = L_inrDup_Start[prev];
            L_bottom_icyl_Start[listIdxBottom]   = L_icyl_Start[prev];
        }

        // --- Far Field Vertices (Systematic N=0, CCW Indexing) ---
        L_bottom_far_Start[listIdxBottom] = vertexCount; // Or listIdx for z=0
        string prefix =
            (listIdxBottom == 1) ? "z0" : "L" + Foam::name(layer) + " Btm";


// Far-field split for the bottom of this layer.  Bottom layer L uses
// horizontal level L-1; therefore bottom(L+1) and top(L) share the same
// split coordinates on external sides.
scalar icylExt_xp = farSplit_xp[layer - 1];
scalar icylExt_xn = farSplit_xn[layer - 1];
scalar icylExt_yp = farSplit_yp[layer - 1];
scalar icylExt_yn = farSplit_yn[layer - 1];

addVertex(vector(0, $atm_y_pos, z_level),
          prefix + " Far N0"); // New Idx 0
addVertex(vector(-icylExt_xn, $atm_y_pos, z_level),
          prefix + " Far N-1"); // New Idx 1
addVertex(vector($atm_x_neg, $atm_y_pos, z_level),
          prefix + " Far NWc"); // New Idx 2
addVertex(vector($atm_x_neg, icylExt_yp, z_level),
          prefix + " Far W1"); // New Idx 3
addVertex(vector($atm_x_neg, 0, z_level),
          prefix + " Far W0"); // New Idx 4
addVertex(vector($atm_x_neg, -icylExt_yn, z_level),
          prefix + " Far W-1"); // New Idx 5
addVertex(vector($atm_x_neg, $atm_y_neg, z_level),
          prefix + " Far SWc"); // New Idx 6
addVertex(vector(-icylExt_xn, $atm_y_neg, z_level),
          prefix + " Far S-1"); // New Idx 7
addVertex(vector(0, $atm_y_neg, z_level),
          prefix + " Far S0"); // New Idx 8
addVertex(vector(icylExt_xp, $atm_y_neg, z_level),
          prefix + " Far S1"); // New Idx 9
addVertex(vector($atm_x_pos, $atm_y_neg, z_level),
          prefix + " Far SEc"); // New Idx 10
addVertex(vector($atm_x_pos, -icylExt_yn, z_level),
          prefix + " Far E-1"); // New Idx 11
addVertex(vector($atm_x_pos, 0, z_level),
          prefix + " Far E0"); // New Idx 12
addVertex(vector($atm_x_pos, icylExt_yp, z_level),
          prefix + " Far E1"); // New Idx 13
addVertex(vector($atm_x_pos, $atm_y_pos, z_level),
          prefix + " Far NEc"); // New Idx 14
addVertex(vector(icylExt_xp, $atm_y_pos, z_level),
          prefix + " Far N1"); // New Idx 15

        addMidOuterVertices(L_bottom_mid_Start[listIdxBottom],
                            L_bottom_icyl_Start[listIdxBottom],
                            L_bottom_far_Start[listIdxBottom],
                            prefix);
        addCornerOuterVertices(L_bottom_cornerSplit_Start[listIdxBottom],
                               L_bottom_icyl_Start[listIdxBottom],
                               L_bottom_mid_Start[listIdxBottom],
                               L_bottom_far_Start[listIdxBottom],
                               prefix);

        z_level = $atm_top_z * layer_fraction[layer];

        r_cr_top = $r_crater_top * pow($exp_fact, layer);

        Info << "top level " << z_level << endl;

        label listIdxTop =
            layer; // Index in lists for vertices at the TOP of this layer

        Info << "Generating vertices for top of Layer " << layer
             << " (z=" << z_level << ", List Index " << listIdxTop << ")"
             << endl;

        // --- Generate TOP vertices for Layer 'layer' ---
        L_center_Start[listIdxTop] = addVertex(
            vector(dx, dy, z_level), "L" + Foam::name(layer) + " Top Ctr");
        makeRing(L_oct_Start[listIdxTop],
                 0.5 * r_cr_top,
                 ringCoeff * cos(radAngle) * 0.5 * r_cr_top,
                 z_level,
                 dx,
                 dy,
                 "L" + Foam::name(layer) + " Top",
                 "Oct");
                 
                 
        makeRing(L_inr_Start[listIdxTop],
                 r_cr_top,
                 r_cr_top * cos(radAngle),
                 z_level,
                 dx,
                 dy,
                 "L" + Foam::name(layer) + " Top",
                 "Inr");
                                                  
        // No duplicate inner ring is required: inner blocks and radial
        // interface blocks are conformal within each layer.
        L_inrDup_Start[listIdxTop] = L_inr_Start[listIdxTop];


        // 1. Calculate scaling parameters for this layer
        // ------------------------------------------------------------------
        // Note: r_cr_top is already defined in your code (crater radius at this layer)

        scalar scale_factor = pow($exp_fact, layer); 
        scalar d_start_curr = actual_crater_top_size * scale_factor; // Target cell size at the crater rim

        // ------------------------------------------------------------------
        // 2. Calculate outer cell counts (N_outer) scaled for this layer
        //    (nx_pos_out_mult etc. are the cell counts at the base layer)
        //    The count halves as the layer index increases (cells get larger)
        // ------------------------------------------------------------------
        int div_factor = pow(2, layer-1); 
        
        label N_xp = Foam::max(1, (int)round(nx_pos_out_mult / (double)div_factor));
        label N_xn = Foam::max(1, (int)round(nx_neg_out_mult / (double)div_factor));
        label N_yp = Foam::max(1, (int)round(ny_pos_out_mult / (double)div_factor));
        label N_yn = Foam::max(1, (int)round(ny_neg_out_mult / (double)div_factor));
        label N_in_outer = Foam::max(1, (int)round(nOuterEdgeInnerFine / (double)div_factor));

        Info << "N_xp " << N_xp  << " N_yp " << N_yp  << "N_xn " << N_xn  << "N_yn " << N_yn
             << " N_in_outer " << N_in_outer << endl;

        // ------------------------------------------------------------------
        // 3. Solve ring parameters for the 4 cardinal directions (Asymmetry)
        //    (Uses r_cr_top as the inner radius)
        // ------------------------------------------------------------------
        RingParams p_xp = solveRingParameters(r_cr_top, d_start_curr, n_rad_gr_interface, mag($atm_x_pos), N_xp, N_in_outer);
        RingParams p_xn = solveRingParameters(r_cr_top, d_start_curr, n_rad_gr_interface, mag($atm_x_neg), N_xn, N_in_outer);
        RingParams p_yp = solveRingParameters(r_cr_top, d_start_curr, n_rad_gr_interface, mag($atm_y_pos), N_yp, N_in_outer);
        RingParams p_yn = solveRingParameters(r_cr_top, d_start_curr, n_rad_gr_interface, mag($atm_y_neg), N_yn, N_in_outer);

        // ------------------------------------------------------------------
        // 4. Select the Minimum Radius (Conservative Strategy)
        //    This defines your new r_icyl to ensure the ring fits within
        //    the domain boundaries in all directions.
        // ------------------------------------------------------------------
        r_icyl = Foam::min(Foam::min(p_xp.R_icyl, p_xn.R_icyl), Foam::min(p_yp.R_icyl, p_yn.R_icyl));

        // ------------------------------------------------------------------
        // 5. Find and Store the Grading corresponding to the chosen radius
        // ------------------------------------------------------------------
        scalar calculated_grading = 1.0;
        
        if      (Foam::mag(r_icyl - p_xp.R_icyl) < 1e-4) calculated_grading = p_xp.grading;
        else if (Foam::mag(r_icyl - p_xn.R_icyl) < 1e-4) calculated_grading = p_xn.grading;
        else if (Foam::mag(r_icyl - p_yp.R_icyl) < 1e-4) calculated_grading = p_yp.grading;
        else                                             calculated_grading = p_yn.grading;

        // IMPORTANT: Store this grading in the list to use it later in the 'blocks' section
        storedGradings[layer] = calculated_grading;
        storedRadiusCyl[layer] = r_icyl;

        Info << "Layer " << layer << " Optimization: r_cr_top=" << r_cr_top 
             << " -> r_icyl=" << r_icyl << " (Grading=" << calculated_grading << ")" << endl;



        makeRing(L_icyl_Start[listIdxTop],
                 r_icyl,
                 r_icyl * cos(radAngle),
                 z_level,
                 dx,
                 dy,
                 "L" + Foam::name(layer) + " Top",
                 "ICyl");

        // --- Far Field Vertices (Systematic N=0, CCW Indexing) ---
        L_far_Start[listIdxTop] = vertexCount; // Or listIdx for z=0
        prefix = (listIdxTop == 1) ? "z0" : "L" + Foam::name(layer) + " Top";

// Far-field split for the top of this layer.  Top layer L uses horizontal
// level L.  The same value is used by the bottom of layer L+1.
icylExt_xp = farSplit_xp[layer];
icylExt_xn = farSplit_xn[layer];
icylExt_yp = farSplit_yp[layer];
icylExt_yn = farSplit_yn[layer];

addVertex(vector(0, $atm_y_pos, z_level),
          prefix + " Far N0"); // New Idx 0
addVertex(vector(-icylExt_xn, $atm_y_pos, z_level),
          prefix + " Far N-1"); // New Idx 1
addVertex(vector($atm_x_neg, $atm_y_pos, z_level),
          prefix + " Far NWc"); // New Idx 2
addVertex(vector($atm_x_neg, icylExt_yp, z_level),
          prefix + " Far W1"); // New Idx 3
addVertex(vector($atm_x_neg, 0, z_level),
          prefix + " Far W0"); // New Idx 4
addVertex(vector($atm_x_neg, -icylExt_yn, z_level),
          prefix + " Far W-1"); // New Idx 5
addVertex(vector($atm_x_neg, $atm_y_neg, z_level),
          prefix + " Far SWc"); // New Idx 6
addVertex(vector(-icylExt_xn, $atm_y_neg, z_level),
          prefix + " Far S-1"); // New Idx 7
addVertex(vector(0, $atm_y_neg, z_level),
          prefix + " Far S0"); // New Idx 8
addVertex(vector(icylExt_xp, $atm_y_neg, z_level),
          prefix + " Far S1"); // New Idx 9
addVertex(vector($atm_x_pos, $atm_y_neg, z_level),
          prefix + " Far SEc"); // New Idx 10
addVertex(vector($atm_x_pos, -icylExt_yn, z_level),
          prefix + " Far E-1"); // New Idx 11
addVertex(vector($atm_x_pos, 0, z_level),
          prefix + " Far E0"); // New Idx 12
addVertex(vector($atm_x_pos, icylExt_yp, z_level),
          prefix + " Far E1"); // New Idx 13
addVertex(vector($atm_x_pos, $atm_y_pos, z_level),
          prefix + " Far NEc"); // New Idx 14
addVertex(vector(icylExt_xp, $atm_y_pos, z_level),
          prefix + " Far N1"); // New Idx 15

        addMidOuterVertices(L_mid_Start[listIdxTop],
                            L_icyl_Start[listIdxTop],
                            L_far_Start[listIdxTop],
                            prefix);
        addCornerOuterVertices(L_cornerSplit_Start[listIdxTop],
                               L_icyl_Start[listIdxTop],
                               L_mid_Start[listIdxTop],
                               L_far_Start[listIdxTop],
                               prefix);

    } // End layer loop

    os << ");" << endl; // End vertices section

    // --- Block, Edge, Boundary, Merge Sections Omitted ---
    // ... These sections need to be generated using the new vertex indices ...

    os << "blocks " << endl;
    os << "(" << endl;

    // Helper to get vertex index (can be defined again locally)
    auto vIdx = [&](label groupStart, int offset) {
        return groupStart + offset;
    };

    auto writeOuterSplitPatchFaces = [&](label icylStart, label midStart, label cornerStart, label farStart, const string& commentPrefix)
    {
        for (int i = 0; i < 4; ++i)
        {
            int icyl_idx_prev = (2 * i + 0) % 8;
            int icyl_idx_corn = (2 * i + 1) % 8;
            int icyl_idx_next = (2 * i + 2) % 8;
            int far_idx_prev0 = (4 * i + 0) % 16;
            int far_idx_prev1 = (4 * i + 1) % 16;
            int far_idx_corn = (4 * i + 2) % 16;
            int far_idx_next1 = (4 * i + 3) % 16;
            int far_idx_next0 = (4 * i + 4) % 16;
            int cBase = 3*i;

            os << "            (" << vIdx(icylStart, icyl_idx_prev) << " "
               << vIdx(midStart, far_idx_prev0) << " "
               << vIdx(midStart, far_idx_prev1) << " "
               << vIdx(icylStart, icyl_idx_corn) << ") // " << commentPrefix
               << " Edge " << i << ".1In" << endl;

            os << "            (" << vIdx(midStart, far_idx_prev0) << " "
               << vIdx(farStart, far_idx_prev0) << " "
               << vIdx(farStart, far_idx_prev1) << " "
               << vIdx(midStart, far_idx_prev1) << ") // " << commentPrefix
               << " Edge " << i << ".1Out" << endl;

            os << "            (" << vIdx(icylStart, icyl_idx_corn) << " "
               << vIdx(midStart, far_idx_prev1) << " "
               << vIdx(cornerStart, cBase + 2) << " "
               << vIdx(midStart, far_idx_next1) << ") // " << commentPrefix
               << " Corner " << i << ".In" << endl;

            os << "            (" << vIdx(midStart, far_idx_prev1) << " "
               << vIdx(farStart, far_idx_prev1) << " "
               << vIdx(cornerStart, cBase + 0) << " "
               << vIdx(cornerStart, cBase + 2) << ") // " << commentPrefix
               << " Corner " << i << ".PrevOut" << endl;

            os << "            (" << vIdx(cornerStart, cBase + 2) << " "
               << vIdx(cornerStart, cBase + 0) << " "
               << vIdx(farStart, far_idx_corn) << " "
               << vIdx(cornerStart, cBase + 1) << ") // " << commentPrefix
               << " Corner " << i << ".FarOut" << endl;

            os << "            (" << vIdx(midStart, far_idx_next1) << " "
               << vIdx(cornerStart, cBase + 2) << " "
               << vIdx(cornerStart, cBase + 1) << " "
               << vIdx(farStart, far_idx_next1) << ") // " << commentPrefix
               << " Corner " << i << ".NextOut" << endl;

            os << "            (" << vIdx(icylStart, icyl_idx_corn) << " "
               << vIdx(midStart, far_idx_next1) << " "
               << vIdx(midStart, far_idx_next0) << " "
               << vIdx(icylStart, icyl_idx_next) << ") // " << commentPrefix
               << " Edge " << i << ".2In" << endl;

            os << "            (" << vIdx(midStart, far_idx_next1) << " "
               << vIdx(farStart, far_idx_next1) << " "
               << vIdx(farStart, far_idx_next0) << " "
               << vIdx(midStart, far_idx_next0) << ") // " << commentPrefix
               << " Edge " << i << ".2Out" << endl;
        }
    };


    // External far-field vertical boundary faces for the conformally split
    // outer corner blocks.  The old 16 Far-Far faces are no longer valid
    // because Far[prev1]-Far[corner] and Far[corner]-Far[next1] are split by
    // the corner split points.  This helper writes the actual exposed faces.
    auto writeOuterFarVerticalPatchFaces = [&](label btmFarStart,
                                               label btmCornerStart,
                                               label topFarStart,
                                               label topCornerStart,
                                               const string& commentPrefix)
    {
        auto writeVFace = [&](label b0, label b1, label t0, label t1, const string& comment)
        {
            os << "            (" << b0 << " " << b1 << " " << t1 << " " << t0
               << ") // " << comment << endl;
        };

        for (int i = 0; i < 4; ++i)
        {
            int far_idx_prev0 = (4*i + 0) % 16;
            int far_idx_prev1 = (4*i + 1) % 16;
            int far_idx_corn  = (4*i + 2) % 16;
            int far_idx_next1 = (4*i + 3) % 16;
            int far_idx_next0 = (4*i + 4) % 16;
            int cBase = 3*i;

            writeVFace(vIdx(btmFarStart, far_idx_prev0),
                       vIdx(btmFarStart, far_idx_prev1),
                       vIdx(topFarStart, far_idx_prev0),
                       vIdx(topFarStart, far_idx_prev1),
                       commentPrefix + " Edge " + Foam::name(i) + ".prev");

            writeVFace(vIdx(btmFarStart, far_idx_prev1),
                       vIdx(btmCornerStart, cBase + 0),
                       vIdx(topFarStart, far_idx_prev1),
                       vIdx(topCornerStart, cBase + 0),
                       commentPrefix + " Corner " + Foam::name(i) + ".prevA");

            writeVFace(vIdx(btmCornerStart, cBase + 0),
                       vIdx(btmFarStart, far_idx_corn),
                       vIdx(topCornerStart, cBase + 0),
                       vIdx(topFarStart, far_idx_corn),
                       commentPrefix + " Corner " + Foam::name(i) + ".prevB");

            writeVFace(vIdx(btmFarStart, far_idx_corn),
                       vIdx(btmCornerStart, cBase + 1),
                       vIdx(topFarStart, far_idx_corn),
                       vIdx(topCornerStart, cBase + 1),
                       commentPrefix + " Corner " + Foam::name(i) + ".nextA");

            writeVFace(vIdx(btmCornerStart, cBase + 1),
                       vIdx(btmFarStart, far_idx_next1),
                       vIdx(topCornerStart, cBase + 1),
                       vIdx(topFarStart, far_idx_next1),
                       commentPrefix + " Corner " + Foam::name(i) + ".nextB");

            writeVFace(vIdx(btmFarStart, far_idx_next1),
                       vIdx(btmFarStart, far_idx_next0),
                       vIdx(topFarStart, far_idx_next1),
                       vIdx(topFarStart, far_idx_next0),
                       commentPrefix + " Edge " + Foam::name(i) + ".next");
        }
    };


// --- Conduit Blocks (Connect Base:Conduit -> Top:CraterBase) ---
    if ($h_conduit > 0)
    {
        os << "    // --- Conduit Blocks ---" << endl;
        label nz = nz_conduit; // Già calcolato sopra
        scalar grading = 1.0; // O un valore calcolato se necessario

        int nr_c = n_crater;
        int na_c = n_crater;

        // Conduit Center Blocks (4 blocks)
        for (int q = 0; q < 4; ++q)
        {
            int oct_idx0 = (q * 2 + 0) % 8;
            int oct_idx1 = (q * 2 + 1) % 8;
            int oct_idx2 = (q * 2 + 2) % 8;

            os << "    hex ("
               // Base Face (z=conduit_base_z) - CCW Winding
               << L_condBase_center  << " "
               << vIdx(L_condBase_oct_Start, oct_idx0) << " "
               << vIdx(L_condBase_oct_Start, oct_idx1) << " "
               << vIdx(L_condBase_oct_Start, oct_idx2)
               << " "
               // Top Face (z=crater_base_z) - Corresponding vertices
               << L_crBase_center << " "
               << vIdx(L_crBase_oct_Start, oct_idx0) << " "
               << vIdx(L_crBase_oct_Start, oct_idx1) << " "
               << vIdx(L_crBase_oct_Start, oct_idx2)
               << ") "
               << "( " << na_c << " " << na_c << " " << nz
               << ") simpleGrading (1 1 " << grading
               << ") // Conduit Ctr Quadrant " << q << endl;
        }

        // Conduit Outer Blocks (8 blocks)
        for (int i = 0; i < 8; ++i)
        {
            int i_plus_1 = (i + 1) % 8;

            os << "    hex ("
               // Base Face (z=conduit_base_z) - CCW Winding
               << vIdx(L_condBase_oct_Start, i) << " "
               << vIdx(L_condBase_outer_Start, i) << " "
               << vIdx(L_condBase_outer_Start, i_plus_1) << " "
               << vIdx(L_condBase_oct_Start, i_plus_1)
               << " "
               // Top Face (z=crater_base_z) - Corresponding vertices
               << vIdx(L_crBase_oct_Start, i) << " "
               << vIdx(L_crBase_outer_Start, i) << " "
               << vIdx(L_crBase_outer_Start, i_plus_1) << " "
               << vIdx(L_crBase_oct_Start, i_plus_1)
               << ") "
               << "( " << na_c << " " << nr_c << " " << nz
               << ") simpleGrading (1 1 " << grading
               << ") // Conduit Outer Segment " << i << endl;
        }
    }

    // --- Crater Blocks (Connect Base:Crater -> Top:z=0) ---
    os << "    // --- Crater Blocks ---" << endl;
    { // Create a scope for crater-specific variables
        label nz = nz_crater;
        scalar grading = z_crater_grading;

        int nr_c = n_crater; // Use coarse counts for crater blocks
        int na_c = n_crater;

        // Crater Center Blocks (4 blocks) - User Defined Topology
        os << "    // Crater Center Blocks (Base: Crater, Top: z=0)" << endl;
        for (int q = 0; q < 4; ++q) // Loop through NW, SW, SE, NE quadrants
        {
            // Define octagon vertex indices for the quadrant's base face (CCW
            // order) q=0 (NW): Ctr, N(0), NW(1), W(2) q=1 (SW): Ctr, W(2),
            // SW(3), S(4) q=2 (SE): Ctr, S(4), SE(5), E(6) q=3 (NE): Ctr, E(6),
            // NE(7), N(0)
            int oct_idx0 = (q * 2 + 0) % 8;
            int oct_idx1 = (q * 2 + 1) % 8;
            int oct_idx2 = (q * 2 + 2) % 8;

            os << "    hex ("
               // Base Face (z=crater_base_z) - CCW Winding: Ctr, V0, V1, V2
               << L_crBase_center << " " // v0 (Center)
               << vIdx(L_crBase_oct_Start, oct_idx0) << " " // v1
               << vIdx(L_crBase_oct_Start, oct_idx1) << " " // v2
               << vIdx(L_crBase_oct_Start, oct_idx2)
               << " " // v3
               // Top Face (z=0) - Corresponding vertices
               << L_bottom_center_Start[1] << " " // v4 (Center @ z=0)
               << vIdx(L_bottom_oct_Start[1], oct_idx0) << " " // v5
               << vIdx(L_bottom_oct_Start[1], oct_idx1) << " " // v6
               << vIdx(L_bottom_oct_Start[1], oct_idx2)
               << ") " // v7
               // Cell counts (nr, na, nz) - Assuming radial along Oct->Ctr,
               // angular along Oct arc For center blocks, nr & na might need
               // swapping depending on definition Let's assume nr is Ctr->Oct,
               // na is along the Oct arc segment for the quadrant
               << "( " << na_c << " " << na_c << " " << nz
               << ") simpleGrading (1 1 " << grading
               << ") // Crater Ctr Quadrant " << q << endl;
        }

        // Crater Outer Blocks (8 blocks) - Connecting CrBase(Oct/Outer) to
        // z=0(Oct/Inr)
        os << "    // Crater Outer Blocks (Base: CrOct/CrOuter -> Top: "
              "z0Oct/z0Inr)"
           << endl;
        for (int i = 0; i < 8;
             ++i) // Loop through the 8 segments (N->NW, NW->W, ...)
        {
            int i_plus_1 = (i + 1) % 8; // Index of the next vertex CCW

            os << "    hex ("
               // Base Face (z=crater_base_z) - CCW Winding: Oct[i], Outer[i],
               // Outer[i+1], Oct[i+1]
               << vIdx(L_crBase_oct_Start, i) << " " // v0
               << vIdx(L_crBase_outer_Start, i) << " " // v1
               << vIdx(L_crBase_outer_Start, i_plus_1) << " " // v2
               << vIdx(L_crBase_oct_Start, i_plus_1)
               << " " // v3
               // Top Face (z=0) - Corresponding vertices: Oct[i], Inr[i],
               // Inr[i+1], Oct[i+1]
               << vIdx(L_bottom_oct_Start[1], i) << " " // v4
               << vIdx(L_bottom_inr_Start[1], i) << " " // v5
               << vIdx(L_bottom_inr_Start[1], i_plus_1) << " " // v6
               << vIdx(L_bottom_oct_Start[1], i_plus_1)
               << ") " // v7
               // Cell counts (na, nr, nz) - Angular along segment, Radial
               // Oct->Outer/Inr
               << "( " << na_c << " " << nr_c << " " << nz
               << ") simpleGrading (1 1 " << grading
               << ") // Crater Outer Segment " << i << endl;
        }

    } // End Crater Blocks scope

    // --- Atmospheric Layers ---
    for (label layer = 1; layer <= $n_vert_layers; ++layer)
    {
        os << "    // --- Layer " << layer << " Blocks ---" << endl;

        // --- Determine layer properties ---
        int h_factor = Foam::max(0, layer - 1);
        int j = pow(2, h_factor); // Horizontal cell count multiplier

        scalar z_bottom;
        if (layer == 1)
        {
            z_bottom = $crater_top_z; // Base of Layer 1 is z=0
        }
        else
        {
            // Bottom Z is the Top Z of the previous layer
            z_bottom = $atm_top_z * layer_fraction[layer - 1];
        }

        scalar z_top = $atm_top_z * layer_fraction[layer];

        int nz_layer;
        scalar grading_layer;
        if (layer == 1)
        {
            nz_layer = nz_out;
            grading_layer = z_out_grading;
        }
        else
        {
            // Compute the grading and vertical number of cells in layer>1
            scalar layer_z = z_top - z_bottom;

            dz_atm_min = hor_cell_size_top_atm / pow(2, $n_vert_layers - layer)
                * atmCells_aspect_ratio_bottom[layer - 1];
            dz_atm_max = hor_cell_size_top_atm / pow(2, $n_vert_layers - layer)
                * atmCells_aspect_ratio_top[layer - 1];

            calculateGradingCells(
                layer_z, dz_atm_min, dz_atm_max, nz_layer, grading_layer);
            Info << atmCells_aspect_ratio_bottom[layer - 1]
                 << atmCells_aspect_ratio_top[layer - 1] << endl;
            Info << " dz_atm_min = " << dz_atm_min
                 << ", dz_atm_max = " << dz_atm_max << endl;
            Info << "Calculated nz_layer = " << nz_layer
                 << ", grading_layer = " << grading_layer << endl;
        }

        // Get Vertex Start Indices
        label L_btm_center = L_bottom_center_Start[layer];
        label L_btm_oct = L_bottom_oct_Start[layer];
        label L_btm_inr = L_bottom_inr_Start[layer];
        label L_btm_inrDup =
            L_bottom_inrDup_Start[layer]; // Not used for these blocks
        label L_btm_icyl = L_bottom_icyl_Start[layer];
        label L_btm_far = L_bottom_far_Start[layer];
        label L_btm_mid = L_bottom_mid_Start[layer];
        label L_btm_corner = L_bottom_cornerSplit_Start[layer];

        label L_top_center = L_center_Start[layer];
        label L_top_oct = L_oct_Start[layer];
        label L_top_inr = L_inr_Start[layer];
        label L_top_inrDup = L_inrDup_Start[layer]; // Not used for these blocks
        label L_top_icyl = L_icyl_Start[layer];
        label L_top_far = L_far_Start[layer];
        label L_top_mid = L_mid_Start[layer];
        label L_top_corner = L_cornerSplit_Start[layer];

        if (nz_layer > 0)
        { // Only define blocks if layer has non-zero cells vertically

            // --- Atmospheric Center Blocks (Ctr -> Oct) ---
            // Layer 1 uses coarse counts. Layers > 1 scale the FINE counts from
            // L1.
            int current_na_ctr;
            current_na_ctr = n_crater;

            Info << "layer " << layer << " current_na_ctr " << current_na_ctr
                 << endl;

            os << "    // L" << layer << " Center Blocks (Ctr->Oct)" << endl;
            for (int q = 0; q < 4; ++q) // Loop through NW, SW, SE, NE quadrants
            {
                int oct_idx0 = (q * 2 + 0) % 8; // N, W, S, E
                int oct_idx1 = (q * 2 + 1) % 8; // NW, SW, SE, NE
                int oct_idx2 = (q * 2 + 2) % 8; // W, S, E, N

                os << "    hex ("
                   // Base Face (z=Lower) - CCW Winding: Ctr, V0, V1, V2
                   << L_btm_center << " " // v0 (Center @ bottom)
                   << vIdx(L_btm_oct, oct_idx0) << " " // v1
                   << vIdx(L_btm_oct, oct_idx1) << " " // v2
                   << vIdx(L_btm_oct, oct_idx2)
                   << " " // v3
                   // Top Face (z=Higher) - Corresponding vertices
                   << L_top_center << " " // v4 (Center @ top)
                   << vIdx(L_top_oct, oct_idx0) << " " // v5
                   << vIdx(L_top_oct, oct_idx1) << " " // v6
                   << vIdx(L_top_oct, oct_idx2)
                   << ") " // v7
                   // Cell counts (na, na, nz) - Use current_na_ctr for planar
                   // counts
                   << "( " << current_na_ctr << " " << current_na_ctr << " "
                   << nz_layer << ") simpleGrading (1 1 " << grading_layer
                   << ") // L" << layer << " Ctr Quadrant " << q << endl;
            }

            // --- Atmospheric Inner Blocks (Octagon -> Inner Circle) ---
            // Angular count (along octagon) must match center blocks.
            // Radial count scales based on coarse count.

            os << "    // L" << layer << " Inner Blocks (Oct->Inr)" << endl;
            for (int i = 0; i < 8; ++i) // Loop through the 8 segments
            {
                int i_plus_1 = (i + 1) % 8; // Index of the next vertex CCW

                os << "    hex ("
                   // Base Face (z=Lower) - CCW Order: Oct[i], Oct[i+1],
                   // Inr[i+1], Inr[i]
                   << vIdx(L_btm_oct, i) << " " // v0
                   << vIdx(L_btm_inr, i) << " " // v3
                   << vIdx(L_btm_inr, i_plus_1) << " " // v2
                   << vIdx(L_btm_oct, i_plus_1)
                   << " " // v1
                   // Top Face (z=Higher) - Corresponding vertices
                   << vIdx(L_top_oct, i) << " " // v4
                   << vIdx(L_top_inr, i) << " " // v7
                   << vIdx(L_top_inr, i_plus_1) << " " // v6
                   << vIdx(L_top_oct, i_plus_1)
                   << ") " // v5
                   // Cell counts (nx ny nz) -> nx along v0->v1 (angular), ny
                   // along v1->v2 (radial) Use n_crater for angular and for
                   // radial
                   << "( " << n_crater << " " << n_crater << " " << nz_layer
                   << ") simpleGrading (1 1 " << grading_layer << ") // L"
                   << layer << " Inner Segment " << i << endl;
            }

            // --- Atmospheric Radial Interface Blocks (Inner Circle ->
            // Intermediate Cylinder) --- Counts for L1 use FINE _mult counts
            // (for radial grading zone). Counts for L>1 scale the BASE fine
            // counts (n_radial_grading, n_angle) by 'j'.

            scalar g_bot = storedGradings[layer-1];
            scalar g_top = storedGradings[layer];
    
            // Grading Verticale e Angolare
            scalar g_vert = grading_layer; // O calculated grading verticale
            scalar g_ang = 1.0;       // Angolare uniforme

            os << "    // L" << layer
               << " Radial Interface Blocks (Inr[Dup?]->Icyl)" << endl;
            for (int i = 0; i < 8; ++i) // Loop through the 8 segments
            {
                int i_plus_1 = (i + 1) % 8; // Index of the next vertex CCW

                os << "    hex ("
                   // Base Face (z=Lower) - CCW Order: Inr[i], Icyl[i],
                   // Icyl[i+1], Inr[i+1] L_radial_base_inner correctly points
                   // to InrDup for L1 base, or Inr for L>1 base
                   << vIdx(L_btm_inrDup, i) << " " // v0
                   << vIdx(L_btm_icyl, i) << " " // v1
                   << vIdx(L_btm_icyl, i_plus_1) << " " // v2
                   << vIdx(L_btm_inrDup, i_plus_1)
                   << " " // v3
                   // Top Face (z=Higher) - Corresponding vertices
                   << vIdx(L_top_inrDup, i) << " " // v4
                   << vIdx(L_top_icyl, i) << " " // v7
                   << vIdx(L_top_icyl, i_plus_1) << " " // v6
                   << vIdx(L_top_inrDup, i_plus_1)
                   << ") " // v5
                   // Cell counts (nx ny nz) -> nx along v0->v1 (radial), ny
                   // along v1->v2 (angular)
                   << "( " << n_rad_gr_interface << " " << n_crater << " "
                   << nz_layer << ") "
                   /*
                   << "simpleGrading (" << rad_gr_val << " 1 "
                   << grading_layer << ") // L" << layer
                   << " Interface Segment " << i << endl;
                   */
                   << "edgeGrading ("
                   << g_bot << " " << g_bot << " " << g_top << " " << g_top << " "  // Dir Radiale (X)
                   << g_ang << " " << g_ang << " " << g_ang << " " << g_ang << " "  // Dir Angolare (Y)
                   << g_vert << " " << g_vert << " " << g_vert << " " << g_vert     // Dir Verticale (Z)
                   << ") " << endl;                   
            }

            // --- Atmospheric Outer Blocks (Icyl -> Far) - Single Loop Strategy
            // --- Calculate scaled cell counts for this layer
            int current_nx_p = nx_pos_out_mult / j;
            int current_nx_n = nx_neg_out_mult / j;
            int current_ny_p = ny_pos_out_mult / j;
            int current_ny_n = ny_neg_out_mult / j;

            os << "    // L" << layer << " Outer Blocks (Icyl->Far)" << endl;
            for (int i = 0; i < 4;
                 ++i) // Loop through 4 quadrants (i=0:N, i=1:W, i=2:S, i=3:E)
            {
                // --- Calculate Indices (with Modulo for wrap-around) ---
                // Icyl Indices (Modulo 8)
                int icyl_idx_prev = (2 * i + 0) % 8; // N, W, S, E
                int icyl_idx_corn = (2 * i + 1) % 8; // NW, SW, SE, NE
                int icyl_idx_next = (2 * i + 2) % 8; // W, S, E, N

                // Far Indices (Modulo 16)
                int far_idx_prev0 = (4 * i + 0) % 16; // N0, W0, S0, E0
                int far_idx_prev1 = (4 * i + 1) % 16; // N-1, W-1, S1, E1
                int far_idx_corn = (4 * i + 2) % 16; // NWc, SWc, SEc, NEc
                int far_idx_next1 = (4 * i + 3) % 16; // W1, S-1, E-1, N1
                int far_idx_next0 = (4 * i + 4) % 16; // W0, S0, E0, N0

                // --- Determine Radial Cell Counts based on Quadrant i ---
                int n1_cor, n2_cor; // Counts for Block 2 (Corner)

                if (i == 0)
                { // North Quadrant (N -> NW -> W)
                    n1_cor = current_nx_n;
                    n2_cor = current_ny_p; // Block 2 (NW corner): nx-, ny+
                }
                else if (i == 1)
                { // West Quadrant (W -> SW -> S)
                    n1_cor = current_ny_n;
                    n2_cor = current_nx_n; // Block 2 (SW corner): nx-, ny-
                }
                else if (i == 2)
                { // South Quadrant (S -> SE -> E)
                    n1_cor = current_nx_p;
                    n2_cor = current_ny_n; // Block 2 (SE corner): nx+, ny-
                }
                else
                { // i == 3, East Quadrant (E -> NE -> N)
                    n1_cor = current_ny_p;
                    n2_cor = current_nx_p; // Block 2 (NE corner): nx+, ny+
                }

                // --- Define the 5 Blocks for this Quadrant ---
                // Block1 and Block3 are split radially into In/Out parts by
                // the intermediate straight edge.  Block2 is left unchanged.
                label nIn = Foam::max(1, nOuterEdgeInnerFine / j);
                label n2_out = Foam::max(1, n2_cor - nIn);
                label n1_out = Foam::max(1, n1_cor - nIn);

                // Block 1In: Previous Edge, inner curved-to-straight part
                os << "    hex ("
                   << vIdx(L_btm_icyl, icyl_idx_prev) << " "
                   << vIdx(L_btm_mid, far_idx_prev0) << " "
                   << vIdx(L_btm_mid, far_idx_prev1) << " "
                   << vIdx(L_btm_icyl, icyl_idx_corn) << " "
                   << vIdx(L_top_icyl, icyl_idx_prev) << " "
                   << vIdx(L_top_mid, far_idx_prev0) << " "
                   << vIdx(L_top_mid, far_idx_prev1) << " "
                   << vIdx(L_top_icyl, icyl_idx_corn) << ") "
                   << "( " << nIn << " " << n_crater << " " << nz_layer
                   << ") simpleGrading (1 1 " << grading_layer << ") // L"
                   << layer << " Outer Edge " << i << ".1In" << endl;

                // Block 1Out: Previous Edge, outer straight-to-far part
                os << "    hex ("
                   << vIdx(L_btm_mid, far_idx_prev0) << " "
                   << vIdx(L_btm_far, far_idx_prev0) << " "
                   << vIdx(L_btm_far, far_idx_prev1) << " "
                   << vIdx(L_btm_mid, far_idx_prev1) << " "
                   << vIdx(L_top_mid, far_idx_prev0) << " "
                   << vIdx(L_top_far, far_idx_prev0) << " "
                   << vIdx(L_top_far, far_idx_prev1) << " "
                   << vIdx(L_top_mid, far_idx_prev1) << ") "
                   << "( " << n2_out << " " << n_crater << " " << nz_layer
                   << ") simpleGrading (1 1 " << grading_layer << ") // L"
                   << layer << " Outer Edge " << i << ".1Out" << endl;

                // Block 2 corner is split into four conformal sub-blocks.
                // This avoids a one-face-to-two-faces mismatch against the
                // adjacent Block1In/Out and Block3In/Out splits.
                int cBase = 3*i;

                // Block 2In: inner corner next to Icyl
                os << "    hex ("
                   << vIdx(L_btm_icyl, icyl_idx_corn) << " "
                   << vIdx(L_btm_mid, far_idx_prev1) << " "
                   << vIdx(L_btm_corner, cBase + 2) << " "
                   << vIdx(L_btm_mid, far_idx_next1) << " "
                   << vIdx(L_top_icyl, icyl_idx_corn) << " "
                   << vIdx(L_top_mid, far_idx_prev1) << " "
                   << vIdx(L_top_corner, cBase + 2) << " "
                   << vIdx(L_top_mid, far_idx_next1) << ") "
                   << "( " << nIn << " " << nIn << " " << nz_layer
                   << ") simpleGrading (1 1 " << grading_layer << ") // L"
                   << layer << " Outer Corner " << i << ".In" << endl;

                // Block 2PrevOut: outer part adjacent to Block1Out
                os << "    hex ("
                   << vIdx(L_btm_mid, far_idx_prev1) << " "
                   << vIdx(L_btm_far, far_idx_prev1) << " "
                   << vIdx(L_btm_corner, cBase + 0) << " "
                   << vIdx(L_btm_corner, cBase + 2) << " "
                   << vIdx(L_top_mid, far_idx_prev1) << " "
                   << vIdx(L_top_far, far_idx_prev1) << " "
                   << vIdx(L_top_corner, cBase + 0) << " "
                   << vIdx(L_top_corner, cBase + 2) << ") "
                   << "( " << n2_out << " " << nIn << " " << nz_layer
                   << ") simpleGrading (1 1 " << grading_layer << ") // L"
                   << layer << " Outer Corner " << i << ".PrevOut" << endl;

                // Block 2FarOut: far corner part
                os << "    hex ("
                   << vIdx(L_btm_corner, cBase + 2) << " "
                   << vIdx(L_btm_corner, cBase + 0) << " "
                   << vIdx(L_btm_far, far_idx_corn) << " "
                   << vIdx(L_btm_corner, cBase + 1) << " "
                   << vIdx(L_top_corner, cBase + 2) << " "
                   << vIdx(L_top_corner, cBase + 0) << " "
                   << vIdx(L_top_far, far_idx_corn) << " "
                   << vIdx(L_top_corner, cBase + 1) << ") "
                   << "( " << n2_out << " " << n1_out << " " << nz_layer
                   << ") simpleGrading (1 1 " << grading_layer << ") // L"
                   << layer << " Outer Corner " << i << ".FarOut" << endl;

                // Block 2NextOut: outer part adjacent to Block3Out
                os << "    hex ("
                   << vIdx(L_btm_mid, far_idx_next1) << " "
                   << vIdx(L_btm_corner, cBase + 2) << " "
                   << vIdx(L_btm_corner, cBase + 1) << " "
                   << vIdx(L_btm_far, far_idx_next1) << " "
                   << vIdx(L_top_mid, far_idx_next1) << " "
                   << vIdx(L_top_corner, cBase + 2) << " "
                   << vIdx(L_top_corner, cBase + 1) << " "
                   << vIdx(L_top_far, far_idx_next1) << ") "
                   << "( " << nIn << " " << n1_out << " " << nz_layer
                   << ") simpleGrading (1 1 " << grading_layer << ") // L"
                   << layer << " Outer Corner " << i << ".NextOut" << endl;

                // Block 3In: Next Edge, inner curved-to-straight part
                os << "    hex ("
                   << vIdx(L_btm_icyl, icyl_idx_corn) << " "
                   << vIdx(L_btm_mid, far_idx_next1) << " "
                   << vIdx(L_btm_mid, far_idx_next0) << " "
                   << vIdx(L_btm_icyl, icyl_idx_next) << " "
                   << vIdx(L_top_icyl, icyl_idx_corn) << " "
                   << vIdx(L_top_mid, far_idx_next1) << " "
                   << vIdx(L_top_mid, far_idx_next0) << " "
                   << vIdx(L_top_icyl, icyl_idx_next) << ") "
                   << "( " << nIn << " " << n_crater << " " << nz_layer
                   << ") simpleGrading (1 1 " << grading_layer << ") // L"
                   << layer << " Outer Edge " << i << ".2In" << endl;

                // Block 3Out: Next Edge, outer straight-to-far part
                os << "    hex ("
                   << vIdx(L_btm_mid, far_idx_next1) << " "
                   << vIdx(L_btm_far, far_idx_next1) << " "
                   << vIdx(L_btm_far, far_idx_next0) << " "
                   << vIdx(L_btm_mid, far_idx_next0) << " "
                   << vIdx(L_top_mid, far_idx_next1) << " "
                   << vIdx(L_top_far, far_idx_next1) << " "
                   << vIdx(L_top_far, far_idx_next0) << " "
                   << vIdx(L_top_mid, far_idx_next0) << ") "
                   << "( " << n1_out << " " << n_crater << " " << nz_layer
                   << ") simpleGrading (1 1 " << grading_layer << ") // L"
                   << layer << " Outer Edge " << i << ".2Out" << endl;

            } // End quadrant loop i

        } // End if (nz_layer > 0)
    } // End layer loop

    os << ");" << endl;

    // --- Edges Definition ---
    Info << "edges" << endl;
    os << "edges" << endl;
    os << "(" << endl;

    // Helper function to generate 8 arcs for a ring (N=0, CCW) using a loop
    auto makeArcs = [&](label ringStartIdx,
                        scalar r,
                        scalar z,
                        scalar dx,
                        scalar dy,
                        const string& commentPrefix) {
        if (ringStartIdx < 0)
            return; // Skip if the ring doesn't exist

        for (int i = 0; i < 8; ++i) // Loop through the 8 segments
        {
            label v_start =
                vIdx(ringStartIdx, i); // Start vertex of arc (N, NW, W, ...)
            label v_end =
                vIdx(ringStartIdx,
                     (i + 1) % 8); // End vertex of arc (NW, W, SW, ...)

            Info << "v_start " << v_start << " v_end " << v_end << endl;

            // Calculate angle for the midpoint of the current arc
            // Angle = 0 is +X (East). Angles increase CCW.
            // Angle of vertex i (N=0, NW=1...) CCW from East is 90 + i*45
            // degrees.
            scalar angle_v_start_deg =
                90.0 + i * 45; 
            scalar angle_mid_deg = angle_v_start_deg
                + 22.5; // Add 22.5 deg CCW for midpoint
            scalar angle_mid_rad = degToRad(angle_mid_deg);

            // Calculate midpoint coordinates
            scalar xArc = dx + r * cos(angle_mid_rad);
            scalar yArc = dy + r * sin(angle_mid_rad);

            // Define the arc edge
            os << "    arc " << v_start << " " << v_end << " (" << xArc << " "
               << yArc << " " << z << ") // " << commentPrefix << " " << i
               << endl;
            Info << "    arc " << v_start << " " << v_end << " (" << xArc << " "
                 << yArc << " " << z << ") // " << commentPrefix << " " << i
                 << endl;
        }
    };

    // --- Define Arcs for Conduit Base Outer Ring ---
    if ($h_conduit > 0)
    {
        scalar dx = $dx_crater_base + $dx_conduit_base;
        scalar dy = $dy_crater_base + $dy_conduit_base;
        makeArcs(L_condBase_outer_Start,
                 r_cond_base,
                 conduit_base_z,
                 dx,
                 dy,
                 "CondBase Outer");
    }

    // --- Define Arcs for Crater Base Outer Ring ---
    {
        scalar dx = $dx_crater_base;
        scalar dy = $dy_crater_base;
        Info << "L_crBase_outer_Start " << L_crBase_outer_Start << endl;
        makeArcs(L_crBase_outer_Start,
                 r_cr_base,
                 crater_base_z,
                 dx,
                 dy,
                 "CrBase Outer");
    }

    // --- Define Arcs for z=0 Inner Circle (Crater Top Edge for Inner Blocks)
    // ---
    {
        scalar dx = 0.0;
        scalar dy = 0.0;
        // Use L_inr_Start[0] which corresponds to the vertices at z=0
        Info << "L_bottom_inr_Start[1] " << L_bottom_inr_Start[1] << endl;
        makeArcs(L_bottom_inr_Start[1],
                 $r_crater_top,
                 $crater_top_z,
                 dx,
                 dy,
                 "z0 Inr");
    }


    if ( !square_flag )
    {
        makeArcs(L_bottom_icyl_Start[1],
             storedRadiusCyl[0],
             $crater_top_z,
             0.0,
             0.0,
             "z0 ExtCyl");
    }         

    label layer = 1;

    makeArcs(L_inr_Start[layer],
             $r_crater_top * pow($exp_fact, layer),
             $atm_top_z * layer_fraction[layer],
             0.0,
             0.0,
             "z0 ExtCyl");

    makeArcs(L_icyl_Start[layer],
             storedRadiusCyl[layer],
             $atm_top_z * layer_fraction[layer],
             0.0,
             0.0,
             "L1 Top ICyl");

    for (label layer = 2; layer <= $n_vert_layers; ++layer)
    {

        makeArcs(L_inr_Start[layer],
                 $r_crater_top * pow($exp_fact, layer),
                 $atm_top_z * layer_fraction[layer],
                 0.0,
                 0.0,
                 "z0 ExtCyl");

        makeArcs(L_icyl_Start[layer],
                 storedRadiusCyl[layer],
                 $atm_top_z * layer_fraction[layer],
                 0.0,
                 0.0,
                 "z0 ExtCyl");

    }

    /*

    // --- Define Arcs for z=0 External Cylinder ---
    {
        scalar dx = 0.0;
        scalar dy = 0.0;
        // Use L_inrDup_Start[0] which corresponds to the duplicate vertices at
        // z=0
        Info << "L_bottom_icyl_Start[1] " << L_bottom_icyl_Start[1] << endl;
        makeArcs(L_bottom_icyl_Start[1],
                 $r_crater_top + ring_width_const,
                 $crater_top_z,
                 dx,
                 dy,
                 "z0 ExtCyl");
    }

    */

    os << ");" << endl; // End edges section

    // --- Edges Definition ---
    os << "boundary" << endl;
    os << "(" << endl;

    // --- terrain_in (Crater Interior Surface - No Conduit Case) ---
    os << "    terrain_in // Crater Internal Surface (Base + Walls)" << endl;
    os << "    {" << endl;
    os << "        type wall;" << endl;
    os << "        inGroups (terrain);" << endl;
    os << "        faces" << endl;
    os << "        (" << endl;

    // --- Conduit Patches (ONLY IF CONDUIT EXISTS) ---
    if ($h_conduit > 0)
    {
        // Base faces of the 4 Center Conduit blocks
        for (int q = 0; q < 4; ++q)
        {
            int oct_idx0 = (q * 2 + 0) % 8;
            int oct_idx1 = (q * 2 + 1) % 8;
            int oct_idx2 = (q * 2 + 2) % 8;
            os << "            (" << L_condBase_center << " "
               << vIdx(L_condBase_oct_Start, oct_idx0) << " "
               << vIdx(L_condBase_oct_Start, oct_idx1) << " "
               << vIdx(L_condBase_oct_Start, oct_idx2) << ") // Conduit Inlet Ctr " << q << endl;
        }

        // Base faces of the 8 Outer Conduit blocks
        for (int i = 0; i < 8; ++i)
        {
            int i_plus_1 = (i + 1) % 8;
            os << "            (" << vIdx(L_condBase_oct_Start, i) << " "
               << vIdx(L_condBase_outer_Start, i) << " "
               << vIdx(L_condBase_outer_Start, i_plus_1) << " "
               << vIdx(L_condBase_oct_Start, i_plus_1) << ") // Conduit Inlet Outer " << i << endl;
        }

        for (int i = 0; i < 8; ++i)
        {
            int i_plus_1 = (i + 1) % 8;
            // Face vertices: CondOuter[i], CrOuter[i], CrOuter[i+1], CondOuter[i+1]
            os << "            (" << vIdx(L_condBase_outer_Start, i) << " "
               << vIdx(L_crBase_outer_Start, i) << " "
               << vIdx(L_crBase_outer_Start, i_plus_1) << " "
               << vIdx(L_condBase_outer_Start, i_plus_1) << ") // Conduit Wall " << i << endl;
        }
    }

    // --- Crater Base Faces ---
    if ($h_conduit == 0)
    {
        os << "            // Crater Base Faces (Center Blocks + Outer Blocks)"
           << endl;
        // Base faces of the 4 Center Crater blocks
        for (int q = 0; q < 4; ++q)
        {
            int oct_idx0 = (q * 2 + 0) % 8;
            int oct_idx1 = (q * 2 + 1) % 8;
            int oct_idx2 = (q * 2 + 2) % 8;
            // Base Face vertices: Ctr, Oct[idx0], Oct[idx1], Oct[idx2]
            os << "            (" << L_crBase_center << " "
               << vIdx(L_crBase_oct_Start, oct_idx0) << " "
               << vIdx(L_crBase_oct_Start, oct_idx1) << " "
               << vIdx(L_crBase_oct_Start, oct_idx2) << ") // Cr Base Ctr Quad "
               << q << endl;
        }
        // Base faces of the 8 Outer Crater blocks
        for (int i = 0; i < 8; ++i)
        {
            int i_plus_1 = (i + 1) % 8;
            // Base Face vertices: CrOct[i], CrOuter[i], CrOuter[i+1], CrOct[i+1]
            os << "            (" << vIdx(L_crBase_oct_Start, i) << " "
               << vIdx(L_crBase_outer_Start, i) << " "
               << vIdx(L_crBase_outer_Start, i_plus_1) << " "
               << vIdx(L_crBase_oct_Start, i_plus_1) << ") // Cr Base Outer Seg "
               << i << endl;
        }
    }    

    // --- Crater Wall Faces ---
    // These are the outermost vertical faces of the 8 Outer Crater blocks.
    // They connect the CrBase Outer Ring to the z=0 Inner Circle Ring.
    os << "            // Crater Wall Faces (Outer faces of Outer Blocks)"
       << endl;
    for (int i = 0; i < 8; ++i)
    {
        int i_plus_1 = (i + 1) % 8;
        // Face vertices: CrOuter[i], z0Inr[i], z0Inr[i+1], CrOuter[i+1]
        // Ensure CCW order when viewed from OUTSIDE the crater (inside the mesh
        // block) Order should be: BottomLeft -> TopLeft -> TopRight ->
        // BottomRight v1(CrOuter[i]) -> v5(z0Inr[i]) -> v6(z0Inr[i+1]) ->
        // v2(CrOuter[i+1])
        os << "            (" << vIdx(L_crBase_outer_Start, i) << " "
           << vIdx(L_bottom_inr_Start[1], i) << " "
           << vIdx(L_bottom_inr_Start[1], i_plus_1) << " "
           << vIdx(L_crBase_outer_Start, i_plus_1) << ") // Cr Wall Seg " << i
           << endl;
    }

    os << "        );" << endl;
    os << "    }" << endl; // End terrain_in

    // --- terrain_out (Outer Ground Surface at z=0) ---
    // Uses the vertices defined as the BOTTOM of Layer 1, accessed via index 1
    // in the L_bottom_*_Start lists.
    Info << "    terrain_out // Outer Ground Surface (z=0)" << endl;
    os << "    terrain_out // Outer Ground Surface (z=0)" << endl;
    os << "    {" << endl;
    os << "        type wall;" << endl;
    os << "        inGroups (terrain);" << endl;
    os << "        faces" << endl;
    os << "        (" << endl;

    // Get Vertex Start Indices for Bottom of Layer 1 (list index 1)
    label L1_btm_inrDup =
        L_bottom_inrDup_Start[1]; // Inner Circle Duplicates @ bottom L1
    label L1_btm_icyl =
        L_bottom_icyl_Start[1]; // Intermediate Cylinder @ bottom L1
    label L1_btm_far = L_bottom_far_Start[1]; // Far Field @ bottom L1
    label L1_btm_mid = L_bottom_mid_Start[1]; // Intermediate straight edge @ bottom L1
    label L1_btm_corner = L_bottom_cornerSplit_Start[1]; // Conformal split points inside outer corner blocks

    // Check if indices are valid (were generated)
    if (L1_btm_inrDup < 0 || L1_btm_icyl < 0 || L1_btm_far < 0 || L1_btm_mid < 0 || L1_btm_corner < 0)
    {
        Info << "Error generating terrain_out: Vertex indices for bottom of "
                "Layer 1 not found."
             << endl;
    }
    else
    {

        // --- Base faces of Layer 1 Radial Interface blocks (InrDup -> Icyl)
        // ---
        os << "            // L1 Radial Interface Blocks Base Faces" << endl;
        for (int i = 0; i < 8; ++i)
        {
            int i_plus_1 = (i + 1) % 8;
            // Base Face (CCW): InrDup[i], InrDup[i+1], Icyl[i+1], Icyl[i]
            os << "            (" << vIdx(L1_btm_inrDup, i) << " "
               << vIdx(L1_btm_inrDup, i_plus_1) << " "
               << vIdx(L1_btm_icyl, i_plus_1) << " " << vIdx(L1_btm_icyl, i)
               << ") // L1 Interface Base " << i << endl;
        }

        // --- Base faces of Layer 1 Outer blocks (Icyl -> Mid -> Far) ---
        os << "            // L1 Outer Blocks Base Faces" << endl;
        writeOuterSplitPatchFaces(L1_btm_icyl, L1_btm_mid, L1_btm_corner, L1_btm_far, "L1 Outer Base");
    } // End else (indices valid)

    os << "        );" << endl;
    os << "    }" << endl << endl; // End terrain_out

    // --- atm (Outer Atmospheric Boundary) ---
    Info << "    atm" << endl;
    os << "    atm" << endl;
    os << "    {" << endl;
    // Choose appropriate type based on your simulation needs
    // e.g., patch, pressureInletOutletVelocity, atmosphere, etc.
    os << "        type patch;" << endl;
    os << "        faces" << endl;
    os << "        (" << endl;

    // Outer loop: Iterate through each atmospheric layer
    for (label layer = 1; layer <= $n_vert_layers; ++layer)
    {
        os << "            // Faces for Layer " << layer << endl;

        // Get Vertex Start Indices for the Far Field ring at the
        // BOTTOM and TOP of the current layer 'layer'
        // Using index 'layer' for both bottom and top based on list definition
        label btmFarStart =
            L_bottom_far_Start[layer]; // Vertices at the base of this layer
        label topFarStart =
            L_far_Start[layer]; // Vertices at the top of this layer

        // Check if indices are valid
        if (btmFarStart < 0 || topFarStart < 0)
        {
            Info << "Error generating atm patch: Vertex indices for layer "
                 << layer << " not found." << endl;
            continue; // Skip to next layer if indices are bad
        }

        label btmCornerStart = L_bottom_cornerSplit_Start[layer];
        label topCornerStart = L_cornerSplit_Start[layer];

        if (btmCornerStart < 0 || topCornerStart < 0)
        {
            Info << "Error generating atm patch: corner split vertex indices for layer "
                 << layer << " not found." << endl;
            continue;
        }

        writeOuterFarVerticalPatchFaces(btmFarStart,
                                        btmCornerStart,
                                        topFarStart,
                                        topCornerStart,
                                        "L" + Foam::name(layer) + " Atm");
    } // End layer loop

    os << "        );" << endl;
    os << "    }" << endl << endl; // End atm patch

    // --- top (Top Atmospheric Boundary) ---
    Info << "    top" << endl;
    os << "    top" << endl;
    os << "    {" << endl;
    // Choose appropriate type: patch, atmosphere, symmetryPlane (if
    // applicable), etc.
    os << "        type patch;" << endl;
    os << "        faces" << endl;
    os << "        (" << endl;

    // Get Vertex Start Indices for the TOP of the FINAL layer (layer = N)
    label N = $n_vert_layers; // Index for the lists holding top vertex indices
    label topCenter = L_center_Start[N];
    label topOct = L_oct_Start[N];
    label topInr = L_inr_Start[N];
    label topInrDup =
        L_inrDup_Start[N]; // Not needed, same as topInr at this level
    label topIcyl = L_icyl_Start[N];
    label topFar = L_far_Start[N];
    label topMid = L_mid_Start[N];
    label topCorner = L_cornerSplit_Start[N];

    // Check if indices are valid
    if (topCenter < 0 || topOct < 0 || topInr < 0 || topIcyl < 0 || topFar < 0 || topMid < 0 || topCorner < 0)
    {
        Info << "Error generating top patch: Vertex indices for top layer ("
             << N << ") not found." << endl;
    }
    else
    {

        os << "            // Top Faces of Layer " << N << " Blocks" << endl;

        // --- Top Faces of Center Blocks (Layer N) ---
        os << "            // Top Faces: Center Blocks (Ctr->Oct)" << endl;
        for (int q = 0; q < 4; ++q) // Loop through NW, SW, SE, NE quadrants
        {
            int oct_idx0 = (q * 2 + 0) % 8; // N, W, S, E
            int oct_idx1 = (q * 2 + 1) % 8; // NW, SW, SE, NE
            int oct_idx2 = (q * 2 + 2) % 8; // W, S, E, N
            // Top Face (CCW Winding): Ctr, V0, V1, V2
            os << "            (" << topCenter << " " // v4 (Center @ top)
               << vIdx(topOct, oct_idx0) << " " // v5
               << vIdx(topOct, oct_idx1) << " " // v6
               << vIdx(topOct, oct_idx2) << ") // Top Ctr Quad " << q << endl;
        }

        // --- Top Faces of Inner Blocks (Layer N) ---
        os << "            // Top Faces: Inner Blocks (Oct->Inr)" << endl;
        for (int i = 0; i < 8; ++i) // Loop through the 8 segments
        {
            int i_plus_1 = (i + 1) % 8;
            // Top Face (CCW Order): Oct[i], Oct[i+1], Inr[i+1], Inr[i]
            os << "            (" << vIdx(topOct, i) << " " // v4
               << vIdx(topOct, i_plus_1) << " " // v5
               << vIdx(topInr, i_plus_1) << " " // v6
               << vIdx(topInr, i) << ") // Top Inner Seg " << i << endl;
        }

        // --- Top Faces of Radial Interface Blocks (Layer N) ---
        os << "            // Top Faces: Radial Interface Blocks (Inr->Icyl)"
           << endl;
        for (int i = 0; i < 8; ++i) // Loop through the 8 segments
        {
            int i_plus_1 = (i + 1) % 8;
            // Top Face (CCW Order): Inr[i], Inr[i+1], Icyl[i+1], Icyl[i]
            os << "            (" << vIdx(topInrDup, i) << " " // v4
               << vIdx(topInrDup, i_plus_1) << " " // v5
               << vIdx(topIcyl, i_plus_1) << " " // v6
               << vIdx(topIcyl, i) << ") // Top Interface Seg " << i << endl;
        }

        // --- Top Faces of Outer Blocks (Layer N) ---
        os << "            // Top Faces: Outer Blocks (Icyl->Mid->Far)" << endl;
        writeOuterSplitPatchFaces(topIcyl, topMid, topCorner, topFar, "Top Outer");

    } // End else (indices valid)

    os << "        );" << endl;
    os << "    }" << endl << endl; // End top patch

    // --- Vertical outer-block interface patches (for mergePatchPairs) ---
    // Only the 12 faces belonging to the outer blocks are duplicated and
    // merged between adjacent atmospheric layers.  The center, inner and
    // radial-interface portions are conformal and reuse the same vertices.
    for (label layer = 1; layer < $n_vert_layers;
         ++layer)
    {
        label L = layer;
        label Lp1 = layer + 1;

        os << "        // --- Outer interface between Layer " << L << " and Layer "
           << Lp1 << " ---" << endl;

        // --- Define top_outer_layer{L} patch ---
        Info << "    top_outer_layer" << L << endl;
        os << "    top_outer_layer" << L << endl;
        os << "    {" << endl;
        os << "        type patch;" << endl;
        os << "        faces" << endl;
        os << "        (" << endl;

        label topIcyl = L_icyl_Start[L];
        label topFar = L_far_Start[L];
        label topMid = L_mid_Start[L];
        label topCorner = L_cornerSplit_Start[L];

        if (topIcyl < 0 || topFar < 0 || topMid < 0 || topCorner < 0)
        {
            Info << "Error generating top_outer_layer" << L
                 << ": Vertex indices not found." << endl;
        }
        else
        {
            writeOuterSplitPatchFaces(topIcyl, topMid, topCorner, topFar, "Top Outer L" + Foam::name(L));
        }

        os << "        );" << endl;
        os << "    }" << endl << endl;

        // --- Define bottom_outer_layer{L+1} patch ---
        Info << "    bottom_outer_layer" << Lp1 << endl;
        os << "    bottom_outer_layer" << Lp1 << endl;
        os << "    {" << endl;
        os << "        type patch;" << endl;
        os << "        faces" << endl;
        os << "        (" << endl;

        label btmIcyl = L_bottom_icyl_Start[Lp1];
        label btmFar = L_bottom_far_Start[Lp1];
        label btmMid = L_bottom_mid_Start[Lp1];
        label btmCorner = L_bottom_cornerSplit_Start[Lp1];

        if (btmIcyl < 0 || btmFar < 0 || btmMid < 0 || btmCorner < 0)
        {
            Info << "Error generating bottom_outer_layer" << Lp1
                 << ": Vertex indices not found." << endl;
        }
        else
        {
            writeOuterSplitPatchFaces(btmIcyl, btmMid, btmCorner, btmFar, "Bottom Outer L" + Foam::name(Lp1));
        }

        os << "        );" << endl;
        os << "    }" << endl << endl;
    }

    // No radial interface patches are needed: inner and radial-interface
    // blocks now share the same vertices within each layer.

    os << ");" << endl;

    // --- Merge Patch Pairs Definition ---
    os << "mergePatchPairs" << endl;
    os << "(" << endl;

    // Outer-block vertical layer merges only
    os << "    // Outer-block vertical layer merges" << endl;
    for (label layer = 1; layer < $n_vert_layers;
         ++layer)
    {
        label L = layer;
        label Lp1 = layer + 1;
        os << "    (top_outer_layer" << L << " bottom_outer_layer" << Lp1 << ")" << endl;
    }

    os << ");" << endl; // End mergePatchPairs section

#}; // End code calculation
}; // End codeStream

