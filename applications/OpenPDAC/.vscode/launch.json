{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug OpenPDAC (foamRun)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${env:FOAM_APPBIN}/foamRun",
            "args": [
                "-case", "${workspaceFolder}/testCase" 
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                { "name": "LD_LIBRARY_PATH", "value": "${env:FOAM_USER_LIBBIN}:${env:FOAM_LIBBIN}:${env:LD_LIBRARY_PATH}" }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
